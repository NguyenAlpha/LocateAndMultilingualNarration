<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Mobile.Pages.StallPopup"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent">

    <Border BackgroundColor="White"
            StrokeShape="RoundRectangle 16"
            Stroke="#E5E7EB"
            StrokeThickness="1"
            Margin="20,0"
            Padding="0">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="0.15" />
        </Border.Shadow>

        <VerticalStackLayout>

            <!-- Header -->
            <Grid Padding="16,14" ColumnDefinitions="*,Auto"
                  BackgroundColor="#F9FAFB">
                <Label Grid.Column="0"
                       x:Name="StallNameLabel"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />

                <Button Grid.Column="1"
                        x:Name="PlayButton"
                        Text="▶ Phát"
                        FontSize="14"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="10"
                        Padding="14,8"
                        Clicked="OnPlayClicked" />
            </Grid>

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="#E5E7EB" />

            <!-- Body -->
            <Label Padding="16,14"
                   Text="Xin chào quý khách"
                   FontSize="14"
                   TextColor="#374151" />

        </VerticalStackLayout>
    </Border>

</toolkit:Popup>
