<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Mobile.Pages.StallPopup"
    CanBeDismissedByTappingOutsideOfPopup="True"
    HorizontalOptions="Fill"
    VerticalOptions="End">

    <!-- Panel chiếm 100% chiều rộng, bo góc trên, neo ở đáy màn hình -->
    <Border BackgroundColor="White"
            StrokeShape="RoundRectangle 24,24,0,0"
            Stroke="Transparent"
            HorizontalOptions="Fill"
            VerticalOptions="End">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-4" Radius="20" Opacity="0.12" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Drag handle -->
            <BoxView Grid.Row="0"
                     WidthRequest="40" HeightRequest="4"
                     CornerRadius="2"
                     Color="#D1D5DB"
                     HorizontalOptions="Center"
                     Margin="0,12,0,8" />

            <!-- Header: tên gian hàng + nút Phát -->
            <Grid Grid.Row="1"
                  Padding="20,0,20,12"
                  ColumnDefinitions="*,Auto">

                <Label Grid.Column="0"
                       x:Name="StallNameLabel"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />

                <Button Grid.Column="1"
                        Text="▶ Phát"
                        FontSize="14"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        CornerRadius="12"
                        Padding="16,10"
                        Clicked="OnPlayClicked" />
            </Grid>

            <!-- Divider -->
            <BoxView Grid.Row="2" HeightRequest="1" Color="#F3F4F6" VerticalOptions="Start" />

            <!-- Body: Description + ScriptText cuộn được -->
            <ScrollView Grid.Row="2" Padding="20,12">
                <VerticalStackLayout Spacing="12">

                    <Label x:Name="DescriptionLabel"
                           FontSize="14"
                           TextColor="#6B7280"
                           FontAttributes="Italic"
                           LineBreakMode="WordWrap"
                           IsVisible="False" />

                    <Label x:Name="ScriptTextLabel"
                           FontSize="15"
                           TextColor="#374151"
                           LineBreakMode="WordWrap" />

                </VerticalStackLayout>
            </ScrollView>


        </Grid>
    </Border>

</toolkit:Popup>
