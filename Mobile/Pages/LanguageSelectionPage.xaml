<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.Pages.LanguageSelectionPage"
    Title="Chọn ngôn ngữ và giọng đọc"
    BackgroundColor="#F6F6F6">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="20" RowSpacing="12">

        <Label
            Grid.Row="0"
            Text="Chọn ngôn ngữ / giọng đọc"
            FontSize="22"
            FontAttributes="Bold" />

        <!-- Bước 1: chọn ngôn ngữ từ API -->
        <VerticalStackLayout Grid.Row="1" Spacing="6">
            <Label Text="Ngôn ngữ" FontAttributes="Bold" />
            <Picker
                ItemsSource="{Binding Languages}"
                ItemDisplayBinding="{Binding DisplayText}"
                SelectedItem="{Binding SelectedLanguage}" />
        </VerticalStackLayout>

        <!-- Bước 2: chọn giọng đọc theo ngôn ngữ đã chọn -->
        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Label Text="Giọng đọc" FontAttributes="Bold" />
            <Picker
                ItemsSource="{Binding Voices}"
                ItemDisplayBinding="{Binding DisplayText}"
                SelectedItem="{Binding SelectedVoice}" />
        </VerticalStackLayout>

        <Label
            Grid.Row="3"
            Text="{Binding ErrorMessage}"
            TextColor="Red"
            IsVisible="{Binding HasError}" />

        <Grid Grid.Row="4" RowDefinitions="Auto,Auto" RowSpacing="16" VerticalOptions="End">
            <Button
                Grid.Row="0"
                Text="Tiếp tục đến bản đồ"
                HeightRequest="48"
                Command="{Binding ConfirmSelectionCommand}" />

            <Grid Grid.Row="1" IsVisible="{Binding IsBusy}">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#6A5AE0" />
                    <Label Text="Đang xử lý..." TextColor="#6A5AE0" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

    </Grid>
</ContentPage>
