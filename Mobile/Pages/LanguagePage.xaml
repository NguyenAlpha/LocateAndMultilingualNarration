<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.LanguagePage"
    Title="Chọn ngôn ngữ"
    BackgroundColor="#F6F6F6">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20">

        <Label Grid.Row="0"
               Text="Chọn ngôn ngữ thuyết minh"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Grid.Row="1"
               Margin="0,8,0,12"
               Text="{Binding SelectedDisplay, StringFormat='Đang chọn: {0}'}"
               TextColor="#555"
               HorizontalOptions="Center" />

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Languages}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#6A5AE0"
                           CornerRadius="15"
                           Padding="15"
                           Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontSize="18" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="{Binding Code}" FontSize="13" TextColor="#D9D9FF"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Chọn"
                                    TextColor="#6A5AE0"
                                    BackgroundColor="White"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectLanguageCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               HorizontalOptions="Center"
               VerticalOptions="End" />

        <!-- OLD CODE
        <VerticalStackLayout Padding="25" Spacing="20">
            ... static language cards with TapGestureRecognizer ...
        </VerticalStackLayout>
        -->

    </Grid>

</ContentPage>