<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mobile.LanguagePage"
             Title="Chọn ngôn ngữ &amp; giọng đọc"
             BackgroundColor="#F8F9FC"
             Padding="20">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="24">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Label Text="Chọn ngôn ngữ thuyết minh"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1F2937"
                   HorizontalOptions="Center"/>
            <Label Text="Nghe rõ ràng hơn bằng tiếng mẹ đẻ"
                   FontSize="15"
                   TextColor="#6B7280"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- SỬA Ở ĐÂY: OLD CODE (kept for reference): Search Bar nằm ở ngoài popup. -->
        <!--
        <Frame Grid.Row="1"
               CornerRadius="25"
               BackgroundColor="White"
               HasShadow="True"
               Padding="16,12">
            <Entry Placeholder="Tìm ngôn ngữ (ví dụ: Việt, Anh, Pháp...)"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   FontSize="16"
                   BackgroundColor="Transparent"
                   ClearButtonVisibility="WhileEditing"
                   TextChanged="OnSearchTextChanged"/>
        </Frame>
        -->

        <!-- SỬA Ở ĐÂY: Vùng hiển thị ngôn ngữ đã chọn + nút mở Popup -->
        <Frame Grid.Row="1"
               CornerRadius="16"
               BackgroundColor="White"
               HasShadow="True"
               Padding="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Ngôn ngữ đang chọn"
                           FontSize="13"
                           TextColor="#6B7280"/>
                    <Label Text="{Binding SelectedLanguage.Name, TargetNullValue='Chưa chọn ngôn ngữ'}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#111827"/>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Chọn"
                        Clicked="OnOpenLanguagePopupClicked"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="14"
                        Padding="16,8"/>
            </Grid>
        </Frame>

        <!-- SỬA Ở ĐÂY: OLD CODE (kept for reference): chọn ngôn ngữ bằng Picker. -->
        <!--
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Label Text="Ngôn ngữ thuyết minh"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#374151"/>
            <Picker ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedLanguage}"
                    ItemDisplayBinding="{Binding Name}"
                    Title="Chọn ngôn ngữ"
                    FontSize="16"/>
        </VerticalStackLayout>
        -->

        <!-- SỬA Ở ĐÂY: Hiển thị danh sách giọng đọc ngay bên dưới ngôn ngữ -->
        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Label Text="Giọng đọc"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#374151"/>

            <!-- SỬA Ở ĐÂY: OLD CODE (kept for reference): dùng Picker cho giọng đọc. -->
            <!--
            <Picker ItemsSource="{Binding AvailableVoices}"
                    SelectedItem="{Binding SelectedVoice}"
                    ItemDisplayBinding="{Binding DisplayText}"
                    Title="Chọn giọng đọc"
                    FontSize="16"/>
            -->

            <CollectionView ItemsSource="{Binding Voices}"
                            SelectedItem="{Binding SelectedVoice, Mode=TwoWay}"
                            SelectionMode="Single"
                            HeightRequest="180">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,4" Padding="10" CornerRadius="12" HasShadow="False" BorderColor="#E5E7EB">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding DisplayName}" FontAttributes="Bold" TextColor="#111827"/>
                                <Label Text="{Binding Description}" FontSize="12" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!-- Cài đặt bổ sung -->
        <VerticalStackLayout Grid.Row="3" Spacing="16">
            <Label Text="Cài đặt thuyết minh"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#374151"/>

            <Frame CornerRadius="16" BackgroundColor="White" Padding="16" HasShadow="True">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="Tốc độ đọc" VerticalOptions="Center" TextColor="#334155"/>
                        <Label Grid.Column="2" Text="{Binding SpeechRateText}" 
                               FontAttributes="Bold" TextColor="#4F46E5" VerticalOptions="Center"/>
                    </Grid>
                    <Slider Minimum="0.5" Maximum="2.0" 
                            Value="{Binding SpeechRate, Mode=TwoWay}"
                            ThumbColor="#4F46E5"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Tự động phát khi mở thuyết minh" 
                               VerticalOptions="Center" TextColor="#334155"/>
                        <Switch IsToggled="{Binding AutoPlay, Mode=TwoWay}" OnColor="#4F46E5"/>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- SỬA Ở ĐÂY: Hiển thị lỗi trên trang chính -->
        <Label Grid.Row="4"
               Text="{Binding ErrorMessage}"
               IsVisible="{Binding HasError}"
               TextColor="#DC2626"
               FontSize="13"/>

        <!-- Button Tiếp tục -->
        <Button Grid.Row="5"
                Text="Xác nhận &amp; Tiếp tục"
                BackgroundColor="#4F46E5"
                TextColor="White"
                CornerRadius="18"
                HeightRequest="56"
                FontSize="17"
                FontAttributes="Bold"
                Command="{Binding ConfirmSelectionCommand}"
                IsEnabled="{Binding IsReadyToContinue}"/>

        <!-- SỬA Ở ĐÂY: Giữ nguyên Popup và hiển thị danh sách ngôn ngữ bên trong Popup -->
        <Grid Grid.RowSpan="6"
              IsVisible="{Binding IsLanguagePopupOpen}"
              BackgroundColor="#80000000"
              ZIndex="10"
              InputTransparent="False">
            <Frame VerticalOptions="Center"
                   HorizontalOptions="Center"
                   WidthRequest="340"
                   MaximumHeightRequest="520"
                   CornerRadius="18"
                   Padding="14"
                   BackgroundColor="White">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
                    <Label Text="Chọn ngôn ngữ"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827"/>

                    <SearchBar Grid.Row="1"
                               Placeholder="Tìm ngôn ngữ..."
                               Text="{Binding SearchText, Mode=TwoWay}"
                               TextChanged="OnSearchTextChanged"/>

                    <CollectionView Grid.Row="2"
                                    ItemsSource="{Binding FilteredLanguages}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnLanguagePopupSelectionChanged">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding FlagEmoji}" FontSize="20" VerticalOptions="Center"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="#111827"/>
                                        <Label Text="{Binding NativeName}" FontSize="12" TextColor="#6B7280"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="22" TextColor="#9CA3AF" VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="3"
                            Text="Đóng"
                            Clicked="OnCloseLanguagePopupClicked"
                            BackgroundColor="#EEF2FF"
                            TextColor="#3730A3"
                            CornerRadius="12"/>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>