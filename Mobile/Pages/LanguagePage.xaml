<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.LanguagePage"
    Title="Chọn ngôn ngữ"
    BackgroundColor="#F6F6F6">

    <Grid RowDefinitions="Auto,*">

        <!-- Title -->
        <Label
            Grid.Row="0"
            Text="Chọn ngôn ngữ thuyết minh"
            FontSize="22"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            Margin="0,25,0,15"/>

        <!-- Loading indicator -->
        <ActivityIndicator
            x:Name="LoadingIndicator"
            Grid.Row="1"
            IsRunning="True"
            IsVisible="True"
            Color="#6A5AE0"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>

        <!-- Language list -->
        <CollectionView
            x:Name="LanguageList"
            Grid.Row="1"
            IsVisible="False"
            Margin="20,0,20,20"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        BackgroundColor="#6A5AE0"
                        Padding="15"
                        Margin="0,0,0,12"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>

                        <HorizontalStackLayout Spacing="15">
                            <Label
                                Text="{Binding FlagEmoji}"
                                FontSize="24"
                                VerticalOptions="Center"/>
                            <Label
                                Text="{Binding DisplayLabel}"
                                FontSize="18"
                                TextColor="White"
                                VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                CommandParameter="{Binding .}"
                                Tapped="OnLanguageTapped"/>
                        </Border.GestureRecognizers>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
