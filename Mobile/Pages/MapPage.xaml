<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.Pages.MapPage"
    NavigationPage.HasNavigationBar="False"
    Title="Bản đồ">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <Grid Grid.Row="0" Padding="16" BackgroundColor="#1E3A8A" ColumnDefinitions="*,Auto">
            <Label Text="🗺 Bản đồ gian hàng (OSM)"
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="18" />

            <Button Grid.Column="1"
                    Text="Làm mới"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="2*,*">
            <!-- OLD CODE (kept for reference):
            <mapsui:MapView x:Name="mapView"
                            Grid.Row="0" />
            -->

            <Border Grid.Row="0" Stroke="#D1D5DB" BackgroundColor="#F8FAFC" Padding="12" Margin="12">
                <Label Text="Bản đồ tương thích net8: tạm ẩn MapView để đảm bảo ứng dụng chạy ổn định.\nBạn vẫn có thể chọn gian hàng từ danh sách bên dưới." TextColor="#334155" />
            </Border>

            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Stalls}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedStall}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="10,6"
                               Padding="12"
                               CornerRadius="14"
                               BorderColor="#D1D5DB">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Id, StringFormat='Booth ID: {0}'}" FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="10" Padding="16,8">
            <Button Grid.Column="0"
                    Text="▶ Phát"
                    Command="{Binding PlayAudioCommand}"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="12" />

            <Button Grid.Column="1"
                    Text="⏸ Tạm dừng"
                    Command="{Binding PauseAudioCommand}"
                    BackgroundColor="#64748B"
                    TextColor="White"
                    CornerRadius="12" />

            <Button Grid.Column="2"
                    Text="⏹ Dừng"
                    Command="{Binding StopAudioCommand}"
                    BackgroundColor="#DC2626"
                    TextColor="White"
                    CornerRadius="12" />
        </Grid>

        <Grid Grid.Row="3" Padding="0,0,0,10">
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center" />
            <Label Text="{Binding ErrorMessage}"
                   HorizontalOptions="Center"
                   VerticalOptions="End"
                   TextColor="Red"
                   FontSize="12" />
        </Grid>

    </Grid>

</ContentPage>