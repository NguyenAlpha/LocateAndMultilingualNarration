<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
    x:Class="Mobile.Pages.ScanPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="Black">

    <Grid>
        <!-- OLD CODE (kept for reference):
        <zxing:CameraBarcodeReaderView
            x:Name="cameraView"
            BarcodesDetected="OnBarcodesDetected"
            IsDetecting="{Binding IsDetecting}" />
        -->

        <!-- Camera preview full màn hình -->
        <zxing:CameraBarcodeReaderView
            x:Name="cameraView"
            BarcodesDetected="OnBarcodesDetected"
            IsDetecting="{Binding IsDetecting}" />

        <!-- Overlay tối hiện đại với vùng focus ở giữa -->
        <Grid RowDefinitions="*,250,*" ColumnDefinitions="*,250,*">
            <!-- 4 vùng tối xung quanh khung scan -->
            <BoxView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Color="#B3000000" />
            <BoxView Grid.Row="1" Grid.Column="0" Color="#B3000000" />
            <BoxView Grid.Row="1" Grid.Column="2" Color="#B3000000" />
            <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Color="#B3000000" />

            <!-- Khung scan ở trung tâm -->
            <Border Grid.Row="1" Grid.Column="1"
                    BackgroundColor="#0DFFFFFF"
                    Stroke="#E6FFFFFF"
                    StrokeThickness="2"
                    Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
            </Border>

            <!-- Góc nhấn mạnh cho khung scan -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="12">
                <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Row="0" Grid.Column="0" Stroke="#FFFFFFFF" StrokeThickness="3" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Stroke="#FFFFFFFF" StrokeThickness="3" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" Stroke="#FFFFFFFF" StrokeThickness="3" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" Stroke="#FFFFFFFF" StrokeThickness="3" WidthRequest="28" HeightRequest="28" BackgroundColor="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Nội dung hướng dẫn và hành động dưới màn hình -->
        <VerticalStackLayout VerticalOptions="End" Padding="20" Spacing="14" Margin="0,0,0,24">
            <Label
                Text="Di chuyển camera đến mã QR để quét"
                TextColor="White"
                HorizontalTextAlignment="Center"
                FontSize="14"
                FontAttributes="Bold" />

            <Border BackgroundColor="#80222222" StrokeThickness="0" Padding="14,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Button
                        Text="Chọn QR từ thư viện ảnh"
                        CornerRadius="14"
                        HeightRequest="46"
                        BackgroundColor="#FF2E2E2E"
                        TextColor="White"
                        Command="{Binding PickImageFromGalleryCommand}" />

                    <!-- <Label
                        Text="Chia sẻ mã QR cá nhân"
                        TextColor="#CCFFFFFF"
                        HorizontalTextAlignment="Center"
                        FontSize="13" />-->

                    <!-- Giữ logic nhập tay hiện có, không xoá feature cũ -->
                    <Entry
                        Placeholder="Nhập boothId hoặc nội dung QR (tuỳ chọn)"
                        Text="{Binding ManualQrInput}"
                        TextColor="White"
                        PlaceholderColor="#99FFFFFF"
                        BackgroundColor="#262626"
                        Margin="0,4,0,0" />

                    <Button
                        Text="Xác nhận"
                        CornerRadius="12"
                        HeightRequest="42"
                        BackgroundColor="#6644AAFF"
                        TextColor="White"
                        Command="{Binding SubmitManualQrCommand}" />
                </VerticalStackLayout>
            </Border>

            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#FFB4B4"
                IsVisible="{Binding HasError}"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Loading khi đang xử lý QR để tránh thao tác lặp -->
        <Grid BackgroundColor="#66000000" IsVisible="{Binding IsBusy}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" />
                <Label Text="Đang xử lý mã QR..." TextColor="White" />
            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
