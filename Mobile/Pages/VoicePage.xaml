<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.Pages.VoicePage"
    Title="Chọn giọng đọc"
    BackgroundColor="#F6F6F6">

    <Grid RowDefinitions="Auto,*">

        <!-- Title -->
        <Label
            Grid.Row="0"
            Text="Chọn giọng thuyết minh"
            FontSize="22"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            Margin="0,25,0,15"/>

        <!-- Loading indicator -->
        <ActivityIndicator
            x:Name="LoadingIndicator"
            Grid.Row="1"
            IsRunning="True"
            IsVisible="True"
            Color="#6A5AE0"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>

        <!-- Empty state -->
        <Label
            x:Name="EmptyLabel"
            Grid.Row="1"
            Text="Không có giọng đọc nào cho ngôn ngữ này."
            FontSize="16"
            TextColor="#999"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            IsVisible="False"/>

        <!-- Voice list -->
        <CollectionView
            x:Name="VoiceList"
            Grid.Row="1"
            IsVisible="False"
            Margin="20,0,20,20"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        BackgroundColor="#6A5AE0"
                        Padding="15"
                        Margin="0,0,0,12"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="4">

                            <HorizontalStackLayout Spacing="10">
                                <Label
                                    Text="{Binding DisplayName}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="White"
                                    VerticalOptions="Center"
                                    HorizontalOptions="FillAndExpand"/>
                                <Border
                                    BackgroundColor="White"
                                    Padding="6,2"
                                    IsVisible="{Binding IsDefault}"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="6"/>
                                    </Border.StrokeShape>
                                    <Label
                                        Text="Mặc định"
                                        FontSize="12"
                                        TextColor="#6A5AE0"/>
                                </Border>
                            </HorizontalStackLayout>

                            <Label
                                Text="{Binding Description}"
                                FontSize="13"
                                TextColor="#DDD"/>

                        </VerticalStackLayout>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                CommandParameter="{Binding .}"
                                Tapped="OnVoiceTapped"/>
                        </Border.GestureRecognizers>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>
