<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Mobile.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Mobile.MainPage"
             BackgroundColor="#F8FAFC"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- ==================== HEADER - ĐÃ THU NHỎ ~50% ==================== -->
        <Grid Grid.Row="0" Padding="20,40,20,20">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4F46E5" Offset="0.0" />
                    <GradientStop Color="#7C3AED" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Spacing="12">
                <!-- Header Bar -->
                <components:HeaderView Title="Home" 
                                       LogoutCommand="{Binding LogoutCommand}" 
                                       Margin="0,0,0,8"/>

                <!-- Welcome -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding HelloText}" 
                           TextColor="#E0E7FF" 
                           FontSize="15" />
                    <Label Text="Khám phá du lịch" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold" />
                    <Label Text="Trải nghiệm gian hàng văn hóa qua thuyết minh đa ngôn ngữ" 
                           TextColor="#C4D0FF" 
                           FontSize="13.5" 
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>

                <!-- Nút Khám phá gần tôi (gọn hơn) -->
                <Button Text="Khám phá gần tôi" 
                        BackgroundColor="White"
                        TextColor="#4F46E5"
                        CornerRadius="30"
                        FontAttributes="Bold"
                        HeightRequest="52"
                        FontSize="16.5"
                        Command="{Binding ExploreNearMeCommand}">
                    <Button.Shadow>
                        <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.12"/>
                    </Button.Shadow>
                </Button>
            </VerticalStackLayout>
        </Grid>

        <!-- ==================== NỘI DUNG CHÍNH ==================== -->
        <ScrollView Grid.Row="1" Padding="20,10,20,20">
            <VerticalStackLayout Spacing="24">

                <!-- Danh sách gian hàng -->
                <Label Text="Danh sách gian hàng"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="#1E2937"/>

                <CollectionView ItemsSource="{Binding FeaturedStalls}"
                                IsVisible="{Binding HasStalls}"
                                SelectionMode="None"
                                HeightRequest="500">
                    <!-- Giới hạn chiều cao để dễ phân trang -->
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="22" Padding="14" BackgroundColor="White" 
                                   HasShadow="True" Margin="0,0,0,14">
                                <Frame.Shadow>
                                    <Shadow Brush="Black" Offset="0,6" Radius="12" Opacity="0.08"/>
                                </Frame.Shadow>
                                <Grid ColumnDefinitions="110, *">
                                    <Frame Grid.Column="0" CornerRadius="16" IsClippedToBounds="True" Padding="0">
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="110"/>
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Padding="14,4,0,0" Spacing="6">
                                        <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold" TextColor="#1F2937"/>
                                        <Label Text="{Binding Description}" FontSize="13.5" TextColor="#64748B" MaxLines="2" LineBreakMode="TailTruncation"/>
                                        <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="8">
                                            <Frame Padding="8,4" CornerRadius="12" BackgroundColor="#EEF2FF" HasShadow="False" BorderColor="#C7D2FE">
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📍" FontSize="12"/>
                                                    <Label Text="{Binding DistanceText}" FontSize="12.5" TextColor="#4338CA" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                            </Frame>
                                            <Frame Grid.Column="1" Padding="8,4" CornerRadius="12" BackgroundColor="#FFF7ED" HasShadow="False" BorderColor="#FED7AA">
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="⭐" FontSize="12" TextColor="#F59E0B"/>
                                                    <Label Text="{Binding RatingText}" FontSize="12.5" TextColor="#9A3412" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                            </Frame>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Phân trang (Pagination) -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="10,0" IsVisible="{Binding HasStalls}">
                    <Button Text="← Trước" 
                            BackgroundColor="White" 
                            TextColor="#64748B"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"/>

                    <Label Text="{Binding CurrentPageDisplay}" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           FontSize="15"
                           TextColor="#475569"/>

                    <Button Text="Sau →" 
                            BackgroundColor="White" 
                            TextColor="#64748B"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"/>
                </Grid>

                <!-- Empty & Loading State -->
                <ActivityIndicator IsVisible="{Binding IsLoadingStalls}" 
                                   IsRunning="{Binding IsLoadingStalls}" 
                                   Color="#4F46E5" HeightRequest="60"/>

                <Label Text="Hiện chưa có gian hàng nào"
                       IsVisible="{Binding HasStalls, Converter={StaticResource InvertedBoolConverter}}"
                       FontSize="15" 
                       TextColor="#94A3B8"
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center"
                       Margin="0,40,0,0"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ==================== BOTTOM NAVIGATION BAR ==================== -->
        <Grid Grid.Row="2" 
              BackgroundColor="White" 
              HeightRequest="76"
              Padding="8,8,8,12"
              ColumnSpacing="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bản đồ -->
            <VerticalStackLayout Grid.Column="0" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="16" BackgroundColor="#F1F5F9" HasShadow="True" Padding="0">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Frame.Shadow>
                    <ImageButton BackgroundColor="Transparent" Command="{Binding MapCommand}">
                        <ImageButton.Source>
                            <FontImageSource Glyph="🗺️" Color="#4F46E5" Size="28"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Frame>
                <Label Text="Bản đồ" FontSize="11" TextColor="#475569" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Ngôn ngữ -->
            <VerticalStackLayout Grid.Column="1" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="16" BackgroundColor="#F1F5F9" HasShadow="True" Padding="0">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Frame.Shadow>
                    <ImageButton BackgroundColor="Transparent" Command="{Binding LanguageCommand}">
                        <ImageButton.Source>
                            <FontImageSource Glyph="🌐" Color="#10B981" Size="28"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Frame>
                <Label Text="Ngôn ngữ" FontSize="11" TextColor="#475569" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Âm thanh 
            <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="16" BackgroundColor="#F1F5F9" HasShadow="True" Padding="0">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Frame.Shadow>
                    <ImageButton BackgroundColor="Transparent" Command="{Binding AudioCommand}">
                        <ImageButton.Source>
                            <FontImageSource Glyph="🔊" Color="#F59E0B" Size="28"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Frame>
                <Label Text="Âm thanh" FontSize="11" TextColor="#475569" HorizontalOptions="Center"/>
            </VerticalStackLayout> -->

            <!-- Gian hàng (đổi từ Âm thanh) -->
            <VerticalStackLayout Grid.Column="2" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="16" BackgroundColor="#F1F5F9" HasShadow="True" Padding="0">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Frame.Shadow>
                    <ImageButton BackgroundColor="Transparent" Command="{Binding StallListCommand}">
                        <ImageButton.Source>
                            <FontImageSource Glyph="🏪" Color="#F59E0B" Size="28"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Frame>
                <Label Text="Gian hàng" FontSize="11" TextColor="#475569" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Hồ sơ -->
            <VerticalStackLayout Grid.Column="3" Spacing="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Frame WidthRequest="54" HeightRequest="54" CornerRadius="16" BackgroundColor="#F1F5F9" HasShadow="True" Padding="0">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Frame.Shadow>
                    <ImageButton BackgroundColor="Transparent" Command="{Binding ProfileCommand}">
                        <ImageButton.Source>
                            <FontImageSource Glyph="👤" Color="#8B5CF6" Size="28"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Frame>
                <Label Text="Hồ sơ" FontSize="11" TextColor="#475569" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
