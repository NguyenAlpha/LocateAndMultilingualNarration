<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:Mobile.Components"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Mobile.MainPage"
             BackgroundColor="#F4F6F9"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid RowDefinitions="Auto, *">

            <Grid Grid.Row="0" Padding="20,40,20,30">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6A11CB" Offset="0.0" />
                        <GradientStop Color="#2575FC" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <components:HeaderView Grid.Row="0" Title="Locate" LogoutCommand="{Binding LogoutCommand}" Margin="0,0,0,20" />

                <VerticalStackLayout Grid.Row="1" Spacing="5" Margin="0,0,0,20">
                    <Label Text="{Binding HelloText}" TextColor="#E0E0E0" FontSize="16" />
                    <Label Text="Khám phá du lịch" TextColor="White" FontSize="26" FontAttributes="Bold" />
                </VerticalStackLayout>

                <Button Grid.Row="2" Text="Bắt đầu khám phá" BackgroundColor="White" TextColor="#2575FC"
                        CornerRadius="24" FontAttributes="Bold" HeightRequest="48" Command="{Binding StartCommand}" />
            </Grid>

            <ScrollView Grid.Row="1" Margin="0,-20,0,0">
                <VerticalStackLayout Spacing="20" Padding="20,0,20,20">

                    <Label Text="Chức năng nhanh" FontSize="18" FontAttributes="Bold" TextColor="#333333" Margin="0,20,0,0"/>
                    <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="15">

                        <VerticalStackLayout Grid.Column="0" Spacing="8" HorizontalOptions="Center">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="16" Padding="0" BackgroundColor="White" BorderColor="Transparent" HasShadow="True">
                                <Frame.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                </Frame.Shadow>
                                <ImageButton BackgroundColor="Transparent" Command="{Binding MapCommand}">
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="🗺" Color="#6A11CB" Size="24"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </Frame>
                            <Label Text="Bản đồ" FontSize="12" HorizontalOptions="Center" TextColor="#555555"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="16" Padding="0" BackgroundColor="White" BorderColor="Transparent" HasShadow="True">
                                <Frame.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                </Frame.Shadow>
                                <ImageButton BackgroundColor="Transparent" Command="{Binding LanguageCommand}">
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="🌐" Color="#00B4DB" Size="24"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </Frame>
                            <Label Text="Ngôn ngữ" FontSize="12" HorizontalOptions="Center" TextColor="#555555"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="Center">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="16" Padding="0" BackgroundColor="White" BorderColor="Transparent" HasShadow="True">
                                <Frame.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                </Frame.Shadow>
                                <ImageButton BackgroundColor="Transparent" Command="{Binding AudioCommand}">
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="🔊" Color="#00C9FF" Size="24"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </Frame>
                            <Label Text="Âm thanh" FontSize="12" HorizontalOptions="Center" TextColor="#555555"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="3" Spacing="8" HorizontalOptions="Center">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="16" Padding="0" BackgroundColor="White" BorderColor="Transparent" HasShadow="True">
                                <Frame.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.05"/>
                                </Frame.Shadow>
                                <ImageButton BackgroundColor="Transparent" Command="{Binding ProfileCommand}">
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="👤" Color="#2575FC" Size="24"/>
                                    </ImageButton.Source>
                                </ImageButton>
                            </Frame>
                            <Label Text="Hồ sơ" FontSize="12" HorizontalOptions="Center" TextColor="#555555"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Gian hàng nổi bật" FontSize="18" FontAttributes="Bold" TextColor="#333333" Margin="0,10,0,0"/>

                    <CollectionView ItemsSource="{Binding FeaturedStalls}" IsVisible="{Binding HasStalls}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame CornerRadius="20" Padding="12" BackgroundColor="White" BorderColor="Transparent" HasShadow="True" Margin="0,0,0,14">
                                    <Frame.Shadow>
                                        <Shadow Brush="Black" Offset="0,5" Radius="10" Opacity="0.08"/>
                                    </Frame.Shadow>
                                    <Grid ColumnDefinitions="100, *">
                                        <Frame Grid.Column="0" CornerRadius="16" Padding="0" IsClippedToBounds="True" HasShadow="False">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="100" />
                                        </Frame>

                                        <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" Spacing="4">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#222222" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Description}" FontSize="12" TextColor="#777777" MaxLines="2" LineBreakMode="TailTruncation"/>
                                            <Grid ColumnDefinitions="*, Auto" Margin="0,5,0,0">
                                                <HorizontalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                                    <Label Text="📍" FontSize="12"/>
                                                    <Label Text="{Binding DistanceText}" FontSize="12" TextColor="#6A11CB" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="⭐" FontSize="12" TextColor="#FF5722"/>
                                                    <Label Text="{Binding RatingText}" FontSize="12" TextColor="#333333" FontAttributes="Bold"/>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <ActivityIndicator IsVisible="{Binding IsLoadingStalls}" IsRunning="{Binding IsLoadingStalls}" Color="#6A11CB" HeightRequest="40"/>

                    <Label Text="Không có gian hàng nổi bật"
                           IsVisible="{Binding HasStalls, Converter={StaticResource InvertedBoolConverter}}"
                           FontSize="14"
                           TextColor="#999999"
                           HorizontalOptions="Center"
                           Margin="0,20,0,10"/>

                    <BoxView HeightRequest="40" Color="Transparent"/>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>