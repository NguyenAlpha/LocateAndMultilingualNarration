<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Mobile.MainPage"
    Title="Trang chủ"
    BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="220,*">

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#C94BFF" Offset="0"/>
                    <GradientStop Color="#6A5CFF" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Padding="20" Spacing="12">

                <!-- USER NAME -->
                <Label
        x:Name="lblUserName"
        Text="Nguyễn Văn A"
        FontSize="18"
        FontAttributes="Bold"
        TextColor="#F0F0F0" />

                <!-- APP TITLE -->
                <Label
        Text="Hướng Dẫn Du Lịch"
        FontSize="24"
        FontAttributes="Bold"
        TextColor="#FFFFFF" />

                <!-- LANGUAGE DISPLAY -->
                <Frame
        BackgroundColor="#FFFFFF15"
        CornerRadius="12"
        Padding="10">

                    <Label
            x:Name="lblLanguageDisplay"
            Text="Ngôn ngữ: Tiếng Việt"
            TextColor="#EAEAEA"
            FontSize="14"/>
                </Frame>

                <!-- DROPDOWN LANGUAGE -->
                <Picker
        x:Name="languagePicker"
        Title="Chọn ngôn ngữ"
        BackgroundColor="#FFFFFF"
        TextColor="Black"
        SelectedIndexChanged="OnLanguageChanged"/>

                <!-- BUTTON -->
                <Button
        Text="Bắt đầu khám phá"
        Clicked="OnStartClicked"
        BackgroundColor="#EDE9FF"
        TextColor="#5A4FCF"
        CornerRadius="20"
        HeightRequest="45"
        WidthRequest="180"/>

            </VerticalStackLayout>
        </Grid>
 
        <!-- CONTENT -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- CARD 1 -->
                <Frame CornerRadius="20" HasShadow="True" Padding="0">
                    <Grid ColumnDefinitions="80,*,Auto">

                        <Image Source="dotnet_bot.png"
                               HeightRequest="80"
                               WidthRequest="80"
                               Aspect="AspectFill"/>

                        <VerticalStackLayout Grid.Column="1" Padding="10,5">
                            <Label Text="Bánh mì Sài Gòn"
                                   FontAttributes="Bold"
                                   FontSize="16"/>

                            <Label Text="Đặc sản Việt Nam"
                                   FontSize="12"
                                   TextColor="Gray"/>

                            <Label Text="200m • ⭐ 4.8"
                                   FontSize="11"
                                   TextColor="#666"/>
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="1"
                               FontSize="20"
                               TextColor="#6A5CFF"
                               VerticalOptions="Center"
                               Margin="10"/>
                    </Grid>
                </Frame>

                <!-- CARD 2 -->
                <Frame CornerRadius="20" HasShadow="True" Padding="0">
                    <Grid ColumnDefinitions="80,*,Auto">

                        <Image Source="dotnet_bot.png"
                               HeightRequest="80"
                               WidthRequest="80"
                               Aspect="AspectFill"/>

                        <VerticalStackLayout Grid.Column="1" Padding="10,5">
                            <Label Text="Phở Hà Nội"
                                   FontAttributes="Bold"
                                   FontSize="16"/>

                            <Label Text="Phở bò truyền thống"
                                   FontSize="12"
                                   TextColor="Gray"/>

                            <Label Text="350m • ⭐ 4.7"
                                   FontSize="11"
                                   TextColor="#666"/>
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="2"
                               FontSize="20"
                               TextColor="#6A5CFF"
                               VerticalOptions="Center"
                               Margin="10"/>
                    </Grid>
                </Frame>

                <!-- QUICK ACTION -->
                <Frame CornerRadius="20" BackgroundColor="White" HasShadow="True">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Chức năng nhanh"
               FontAttributes="Bold"
               FontSize="16"/>

                        <Grid ColumnDefinitions="*,*,*">

                            <!-- MAP -->
                            <Button Text="🗺 Bản đồ"
                    Clicked="OnMapClicked"
                    BackgroundColor="#6A5CFF"
                    TextColor="White"
                    CornerRadius="12"/>

                            <!-- LANGUAGE -->
                            <Button Text="🌐 Ngôn ngữ"
                    Clicked="OnLanguageClicked"
                    BackgroundColor="#C94BFF"
                    TextColor="White"
                    CornerRadius="12"/>

                            <!-- AUDIO -->
                            <Button x:Name="btnAudio"
                    Text="🔊 Audio"
                    Clicked="OnAudioClicked"
                    BackgroundColor="#FF7A7A"
                    TextColor="White"
                    CornerRadius="12"/>

                        </Grid>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>