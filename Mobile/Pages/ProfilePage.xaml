<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mobile.Pages.ProfilePage"
             Title="Hồ sơ cá nhân"
             BackgroundColor="#F8FAFC">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="26">

            <!-- Avatar và thông tin người dùng -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                <Frame WidthRequest="128" HeightRequest="128"
                       CornerRadius="64"
                       BackgroundColor="White"
                       HasShadow="True"
                       Padding="6"
                       IsClippedToBounds="True">
                    <!-- OLD CODE (kept for reference):
                         <Image Source="{Binding UserAvatar}"
                                Aspect="AspectFill"
                                WidthRequest="116"
                                HeightRequest="116"
                                CornerRadius="58"/>
                    -->
                    <!-- Image trong MAUI không có CornerRadius trực tiếp, dùng Frame lồng để bo góc tránh crash XAML parser -->
                    <Frame WidthRequest="116"
                           HeightRequest="116"
                           CornerRadius="58"
                           Padding="0"
                           HasShadow="False"
                           IsClippedToBounds="True"
                           BackgroundColor="Transparent">
                        <Image Source="{Binding UserAvatar}"
                               Aspect="AspectFill"
                               WidthRequest="116"
                               HeightRequest="116"/>
                    </Frame>
                </Frame>

                <Label Text="{Binding UserName}"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1E2937"
                       HorizontalOptions="Center"/>

                <Label Text="{Binding UserEmail}"
                       FontSize="15"
                       TextColor="#64748B"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Ngôn ngữ ưu tiên -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Ngôn ngữ thuyết minh ưu tiên"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1E2937"/>

                <Frame CornerRadius="16" BackgroundColor="White" Padding="16" HasShadow="True">
                    <Picker ItemsSource="{Binding AvailableLanguages}"
                            SelectedItem="{Binding SelectedLanguage}"
                            ItemDisplayBinding="{Binding Name}"
                            Title="Chọn ngôn ngữ thuyết minh"
                            FontSize="16"
                            HorizontalOptions="Fill"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Cài đặt giọng đọc & tốc độ -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Cài đặt thuyết minh"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#1E2937"/>

                <Frame CornerRadius="16" BackgroundColor="White" Padding="18" HasShadow="True">
                    <VerticalStackLayout Spacing="20">

                        <!-- Giọng đọc -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Giọng đọc" 
                                   FontSize="15" 
                                   FontAttributes="Bold" 
                                   TextColor="#334155"/>
                            <Picker ItemsSource="{Binding AvailableVoices}"
                                    SelectedItem="{Binding SelectedVoice}"
                                    ItemDisplayBinding="{Binding DisplayText}"
                                    Title="Chọn giọng đọc"
                                    FontSize="16"/>
                        </VerticalStackLayout>

                        <!-- Tốc độ đọc -->
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0"
                                       Text="Tốc độ đọc"
                                       FontSize="15"
                                       TextColor="#334155"
                                       VerticalOptions="Center"/>
                                <Label Grid.Column="2"
                                       Text="{Binding SpeechRateText}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#4F46E5"
                                       VerticalOptions="Center"/>
                            </Grid>
                            <Slider Minimum="0.5"
                                    Maximum="2.0"
                                    Value="{Binding SpeechRate, Mode=TwoWay}"
                                    ThumbColor="#4F46E5"/>
                        </VerticalStackLayout>

                        <!-- Tự động phát -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="Tự động phát khi mở thuyết minh"
                                   FontSize="15"
                                   TextColor="#334155"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap"/>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding AutoPlay, Mode=TwoWay}"
                                    OnColor="#4F46E5"/>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <!-- Trạng thái -->
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Color="#4F46E5"
                               HeightRequest="40"/>

            <!-- Nút hành động -->
            <VerticalStackLayout Spacing="14">
                <Button Text="Lưu thay đổi cấu hình"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        CornerRadius="18"
                        HeightRequest="56"
                        FontSize="17"
                        FontAttributes="Bold"
                        Command="{Binding SaveProfileCommand}"/>

                <Button Text="Đăng xuất"
                        BackgroundColor="Transparent"
                        TextColor="#EF4444"
                        BorderColor="#EF4444"
                        BorderWidth="1.5"
                        CornerRadius="18"
                        HeightRequest="52"
                        FontSize="16"
                        Command="{Binding LogoutCommand}"/>
            </VerticalStackLayout>

            <Label Text="Phiên bản 1.3.0 • Đồ án tốt nghiệp"
                   FontSize="12"
                   TextColor="#94A3B8"
                   HorizontalOptions="Center"
                   Margin="0,30,0,10"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>