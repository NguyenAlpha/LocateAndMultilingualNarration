@model Web.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - EMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
    <style>
        .page { animation: pageFadeIn 0.4s ease-in; }
        @@keyframes pageFadeIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
        .card { animation: cardSlide 0.4s ease-out 0.1s both; }
        @@keyframes cardSlide { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
        .btn { transition: transform 0.15s ease; }
        .btn:not(:disabled):hover { transform: translateY(-1px); }
    </style>
</head>
<body class="d-flex flex-column">
    <div class="page page-center">
        <div class="container container-tight py-4">

            <!-- Brand -->
            <div class="text-center mb-4">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand navbar-brand-autodark">
                    <span class="fs-2 fw-bold">
                        <i class="ti ti-building me-2 text-primary"></i>EMS
                    </span>
                </a>
            </div>

            <div class="text-center mb-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-ghost-secondary btn-sm">
                    <i class="ti ti-arrow-left me-1"></i>Quay lại trang chủ
                </a>
            </div>

            <div class="card card-md">
                <div class="card-body">
                    <h2 class="h2 text-center mb-1">Đăng nhập tài khoản</h2>
                    <p class="text-muted text-center mb-4">Hệ thống Quản lý Doanh nghiệp</p>

                    <form asp-action="Login" asp-controller="Auth" method="post" novalidate autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email hoặc tên đăng nhập</label>
                            <input asp-for="Email"
                                   class="form-control"
                                   placeholder="Email hoặc username"
                                   autocomplete="username"
                                   maxlength="256"
                                   required>
                            <span asp-validation-for="Email" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-2">
                            <label asp-for="Password" class="form-label">
                                Mật khẩu
                                <span class="form-label-description">
                                    <a href="#" tabindex="-1">Quên mật khẩu?</a>
                                </span>
                            </label>
                            <div class="input-group input-group-flat">
                                <input asp-for="Password"
                                       class="form-control"
                                       placeholder="Nhập mật khẩu"
                                       autocomplete="current-password"
                                       id="passwordInput"
                                       maxlength="128"
                                       required>
                                <span class="input-group-text">
                                    <a href="#" class="link-secondary" id="togglePassword" title="Hiện mật khẩu" tabindex="-1">
                                        <i class="ti ti-eye" id="toggleIcon"></i>
                                    </a>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="invalid-feedback d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-check">
                                <input asp-for="RememberMe" class="form-check-input">
                                <span class="form-check-label">Ghi nhớ đăng nhập trên thiết bị này</span>
                            </label>
                        </div>

                        <div class="form-footer">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="ti ti-login me-2"></i>Đăng nhập
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center text-muted mt-3">
                Chưa có tài khoản?
                <a asp-controller="Auth" asp-action="Register">Tạo tài khoản mới</a>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('togglePassword').addEventListener('click', function (e) {
            e.preventDefault();
            var input = document.getElementById('passwordInput');
            var icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'ti ti-eye-off';
            } else {
                input.type = 'password';
                icon.className = 'ti ti-eye';
            }
        });
    </script>
</body>
</html>
