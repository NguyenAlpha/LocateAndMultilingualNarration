@model Web.Models.StallGeoFenceManagementViewModel

@{
    ViewData["Title"] = "Quản lý Stall GeoFences";
}

<div class="page-header">
    <h1>Quản lý Stall GeoFences</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="get" class="row g-3 mb-3">
            <div class="col-md-4">
                <select name="stallId" class="form-select">
                    <option value="">-- Chọn stall --</option>
                    @foreach (var s in Model.Stalls)
                    {
                        <option value="@s.Id" selected="@(Model.StallId == s.Id)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary">Lọc</button>
            </div>
        </form>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Stall</th>
                    <th>Polygon Json</th>
                    <th>MinZoom</th>
                    <th>MaxZoom</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.StallId</td>
                        <td style="max-width:400px; overflow:auto;">@item.PolygonJson</td>
                        <td>@item.MinZoom</td>
                        <td>@item.MaxZoom</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <a href="#" class="btn btn-success">Tạo mới</a>
        </div>
    </div>
</div>
