@model Web.Models.StallNarrationContentManagementViewModel
@{
    ViewData["Title"] = "Quản lý Nội dung Thuyết minh";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
    var stallLookup = Model.Stalls.ToDictionary(s => s.Id, s => s.Name);
    var languageLookup = Model.Languages.ToDictionary(l => l.Id, l => l.Name);
}

<!-- Page Header -->
<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="#">Quản lý</a></li>
            <li class="breadcrumb-item active" aria-current="page">Nội dung Thuyết minh</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1><i class="bi bi-mic me-2"></i>Nội dung Thuyết minh</h1>
            <p class="text-muted mb-0">Quản lý nội dung thuyết minh theo gian hàng và ngôn ngữ.</p>
        </div>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-upload me-1"></i>Xuất dữ liệu
            </button>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createNarrationContentModal">
                <i class="bi bi-plus-lg me-1"></i>Thêm nội dung thuyết minh
            </button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Search/Filter -->
<div class="search-filter-bar">
    <form method="get" asp-action="StallNarrationContents" class="row g-3">
        <div class="col-md-4">
            <label for="narrationSearch" class="form-label visually-hidden">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control table-search" id="narrationSearch" name="search" value="@Model.Search" placeholder="Tìm theo tiêu đề hoặc mô tả...">
            </div>
        </div>
        <div class="col-md-2">
            <label for="stallFilter" class="form-label visually-hidden">Stall</label>
            <select class="form-select" id="stallFilter" name="stallId" aria-label="Filter by stall">
                <option value="">Tất cả stall</option>
                @foreach (var stall in Model.Stalls)
                {
                    <option value="@stall.Id" selected="@(Model.StallId == stall.Id)">@stall.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="languageFilter" class="form-label visually-hidden">Language</label>
            <select class="form-select" id="languageFilter" name="languageId" aria-label="Filter by language">
                <option value="">Tất cả ngôn ngữ</option>
                @foreach (var language in Model.Languages)
                {
                    <option value="@language.Id" selected="@(Model.LanguageId == language.Id)">@language.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label for="statusFilter" class="form-label visually-hidden">Status</label>
            <select class="form-select" id="statusFilter" name="isActive" aria-label="Filter by status">
                <option value="" selected="@(Model.IsActive == null)">Tất cả trạng thái</option>
                <option value="true" selected="@(Model.IsActive == true)">Active</option>
                <option value="false" selected="@(Model.IsActive == false)">Inactive</option>
            </select>
        </div>
        <div class="col-md-1">
            <label for="pageSize" class="form-label visually-hidden">Page size</label>
            <select class="form-select" id="pageSize" name="pageSize" aria-label="Page size">
                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                <option value="25" selected="@(Model.PageSize == 25)">25</option>
                <option value="50" selected="@(Model.PageSize == 50)">50</option>
            </select>
        </div>
        <div class="col-md-1 d-grid">
            <button class="btn btn-outline-secondary" type="submit">
                <i class="bi bi-filter"></i>
            </button>
        </div>
        <div class="col-md-12">
            <a class="btn btn-outline-secondary" asp-action="StallNarrationContents">
                <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
            </a>
        </div>
    </form>
</div>

<!-- Narration Contents Table -->
<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover" aria-label="Narration content list">
            <thead>
                <tr>
                    <th scope="col">Tiêu đề</th>
                    <th scope="col">Gian hàng</th>
                    <th scope="col">Ngôn ngữ gốc</th>
                    <th scope="col">TTS</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Cập nhật</th>
                    <th scope="col" class="no-export">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Chưa có narration content.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        var statusClass = item.IsActive ? "success" : "secondary";
                        var statusText = item.IsActive ? "Hoạt động" : "Tạm dừng";
                        var (ttsBadge, ttsText, ttsTitle) = item.TtsStatus switch
                        {
                            "Pending"    => ("bg-warning text-dark", "Chờ",        "Đang chờ xử lý TTS"),
                            "Processing" => ("bg-info text-white",   "Đang tạo",   "TTS đang chạy"),
                            "Completed"  => ("bg-success",            "Hoàn thành", "TTS hoàn thành"),
                            "Failed"     => ("bg-danger",             "Lỗi",        item.TtsError ?? "TTS thất bại"),
                            _            => ("bg-secondary",          "–",          "Chưa có TTS"),
                        };
                        var stallName = stallLookup.TryGetValue(item.StallId, out var stallValue) ? stallValue : item.StallId.ToString();
                        var languageName = languageLookup.TryGetValue(item.LanguageId, out var langValue) ? langValue : item.LanguageId.ToString();
                        <tr>
                            <td>
                                <strong>@item.Title</strong>
                                <small class="d-block text-muted">ID: @item.Id</small>
                            </td>
                            <td>@stallName</td>
                            <td>@languageName</td>
                            <td>
                                <span class="badge @ttsBadge" title="@ttsTitle">@ttsText</span>
                            </td>
                            <td><span class="badge bg-@statusClass">@statusText</span></td>
                            <td>@(item.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td>
                                <div class="btn-group">
                                    @* <button type="button" class="btn btn-sm btn-outline-primary" title="Edit" disabled>
                                        <i class="bi bi-pencil"></i>
                                    </button> *@
                                    <a class="btn btn-sm btn-outline-info" title="View/Edit" asp-controller="Narration" asp-action="Show" asp-route-id="@item.Id">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <button type="button"
                                            class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(item.IsActive ? "Deactivate" : "Activate")"
                                            data-bs-toggle="modal"
                                            data-bs-target="#toggleStatusModal"
                                            data-id="@item.Id"
                                            data-title="@item.Title"
                                            data-is-active="@item.IsActive.ToString().ToLowerInvariant()">
                                        <i class="bi @(item.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
        <div class="text-muted">
            Hiển thị @startIndex-@endIndex trong tổng @Model.TotalCount bản ghi
        </div>
        <nav aria-label="Narration pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="StallNarrationContents" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId" asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="StallNarrationContents" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId" asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="StallNarrationContents" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-stallId="@Model.StallId" asp-route-languageId="@Model.LanguageId" asp-route-isActive="@Model.IsActive" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Toggle Status Confirmation Modal -->
<div class="modal fade" id="toggleStatusModal" tabindex="-1" aria-labelledby="toggleStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Narration" asp-action="ToggleStatus" method="post" id="toggleStatusForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="toggleStatusId">
                <input type="hidden" name="isActive" id="toggleStatusIsActive">
                <div class="modal-header">
                    <h5 class="modal-title" id="toggleStatusModalLabel">
                        <i class="bi bi-toggle-on me-2"></i>Xác nhận đổi trạng thái
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p id="toggleStatusMessage"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn" id="toggleStatusConfirmBtn">Xác nhận</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Form validation: create narration content modal
    (function () {
        var form = document.getElementById('createNarrationForm');
        if (!form) return;
        form.addEventListener('submit', function (e) {
            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            }
            form.classList.add('was-validated');
        });
        // Reset validation state khi đóng modal
        document.getElementById('createNarrationContentModal').addEventListener('hidden.bs.modal', function () {
            form.classList.remove('was-validated');
            form.reset();
        });
    })();

    document.getElementById('toggleStatusModal').addEventListener('show.bs.modal', function (event) {
        var btn = event.relatedTarget;
        var id = btn.getAttribute('data-id');
        var title = btn.getAttribute('data-title');
        var isActive = btn.getAttribute('data-is-active') === 'true';
        var newState = !isActive;

        document.getElementById('toggleStatusId').value = id;
        document.getElementById('toggleStatusIsActive').value = newState;

        var message = document.getElementById('toggleStatusMessage');
        var confirmBtn = document.getElementById('toggleStatusConfirmBtn');

        if (newState) {
            message.innerHTML = 'Bạn có chắc muốn <strong>kích hoạt</strong> nội dung <strong>"' + title + '"</strong>?<br><small class="text-muted">Các nội dung khác của cùng stall sẽ bị deactivate.</small>';
            confirmBtn.className = 'btn btn-success';
            confirmBtn.textContent = 'Kích hoạt';
        } else {
            message.innerHTML = 'Bạn có chắc muốn <strong>vô hiệu hóa</strong> nội dung <strong>"' + title + '"</strong>?';
            confirmBtn.className = 'btn btn-warning';
            confirmBtn.textContent = 'Vô hiệu hóa';
        }
    });
</script>

<!-- Create Narration Content Modal -->
<div class="modal fade" id="createNarrationContentModal" tabindex="-1" aria-labelledby="createNarrationContentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-controller="Narration" asp-action="Create" method="post"
                  id="createNarrationForm" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="createNarrationContentModalLabel">
                        <i class="bi bi-plus-circle me-2"></i>Thêm nội dung Narration
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="createStallId" class="form-label">Stall <span class="text-danger">*</span></label>
                            <select class="form-select" id="createStallId" name="StallId" required>
                                <option value="">-- Chọn stall --</option>
                                @foreach (var stall in Model.Stalls)
                                {
                                    <option value="@stall.Id">@stall.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">Vui lòng chọn gian hàng.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="createLanguageId" class="form-label">Ngôn ngữ gốc <span class="text-danger">*</span></label>
                            <select class="form-select" id="createLanguageId" name="LanguageId" required>
                                <option value="">-- Chọn ngôn ngữ gốc --</option>
                                @foreach (var language in Model.Languages)
                                {
                                    <option value="@language.Id">@language.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">Vui lòng chọn ngôn ngữ.</div>
                        </div>
                        <div class="col-12">
                            <label for="createTitle" class="form-label">Tiêu đề <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="createTitle" name="Title"
                                   required minlength="2" maxlength="128" placeholder="Nhập tiêu đề...">
                            <div class="invalid-feedback">Tiêu đề là bắt buộc (2–128 ký tự).</div>
                        </div>
                        <div class="col-12">
                            <label for="createDescription" class="form-label">Mô tả</label>
                            <input type="text" class="form-control" id="createDescription" name="Description"
                                   maxlength="256" placeholder="Nhập mô tả (tùy chọn)...">
                        </div>
                        <div class="col-12">
                            <label for="createScriptText" class="form-label">Nội dung kịch bản <span class="text-danger">*</span></label>
                            <textarea class="form-control" id="createScriptText" name="ScriptText"
                                      rows="5" required minlength="10"
                                      placeholder="Nhập nội dung kịch bản..."></textarea>
                            <div class="invalid-feedback">Kịch bản là bắt buộc (tối thiểu 10 ký tự).</div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="createIsActive" name="IsActive" value="true" checked>
                                <label class="form-check-label" for="createIsActive">Hoạt động</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Tạo nội dung & thuyết minh tự động
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
