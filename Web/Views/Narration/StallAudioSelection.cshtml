
@{
    ViewData["Title"] = "StallAudioSelection";
}

@section Styles {
    <style>
        .stall-selection-container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .stall-card {
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid #dee2e6;
            height: 100%;
        }

            .stall-card:hover {
                border-color: #0d6efd;
                box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15);
                transform: translateY(-2px);
            }

            .stall-card.selected {
                border-color: #0d6efd;
                background-color: #f0f7ff;
            }

        .stall-card-body {
            padding: 20px;
        }

        .stall-id {
            font-size: 12px;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stall-name {
            font-size: 18px;
            font-weight: 600;
            color: #212529;
            margin-bottom: 10px;
        }

        .stall-info {
            font-size: 14px;
            color: #495057;
            margin-bottom: 8px;
        }

        .stall-info-icon {
            width: 20px;
            display: inline-block;
            color: #0d6efd;
        }

        .status-badge {
            display: inline-block;
            margin-top: 10px;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state-icon {
            font-size: 64px;
            color: #dee2e6;
            margin-bottom: 20px;
        }

        .search-box {
            margin-bottom: 30px;
        }

        .filter-group {
            margin-bottom: 20px;
        }

        .action-buttons {
            position: sticky;
            bottom: 0;
            background: white;
            border-top: 1px solid #dee2e6;
            padding: 20px 0;
            margin-top: 40px;
        }

        .selection-counter {
            color: #6c757d;
            font-size: 14px;
        }

        @@media (max-width: 768px) {
            .stall-card-body {
                padding: 15px;
            }

            .stall-name {
                font-size: 16px;
            }

            .stall-info {
                font-size: 12px;
            }
        }
    </style>
}

<!-- Page Header -->
<div class="page-header mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Pages/Home/Index.html">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Select Stall for Audio</li>
        </ol>
    </nav>
    <h1><i class="bi bi-mic me-2"></i>Select Stall for Audio Management</h1>
    <p class="text-muted mt-2">Choose a stall to manage its audio content and voice settings</p>
</div>

<!-- Stall Selection Container -->
<div class="stall-selection-container">
    <!-- Search and Filter -->
    <div class="search-box">
        <div class="row g-2">
            <div class="col-md-6">
                <input type="text" class="form-control" id="stallSearch" placeholder="Search by stall ID or business name..."
                       aria-label="Search stalls">
            </div>
            <div class="col-md-3">
                <select class="form-select" id="zoneFilter" aria-label="Filter by zone">
                    <option value="">All Zones</option>
                    <option value="A">Zone A</option>
                    <option value="B">Zone B</option>
                    <option value="C">Zone C</option>
                    <option value="D">Zone D</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" id="statusFilter" aria-label="Filter by status">
                    <option value="">All Status</option>
                    <option value="occupied">Occupied</option>
                    <option value="available">Available</option>
                    <option value="reserved">Reserved</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Stalls Grid -->
    <div class="row" id="stallsGrid">
        <!-- Populated by JavaScript -->
    </div>

    <!-- Empty State -->
    <div class="empty-state" id="emptyState" style="display: none;">
        <div class="empty-state-icon">
            <i class="bi bi-inbox"></i>
        </div>
        <h5>No Stalls Found</h5>
        <p class="text-muted">Try adjusting your search or filter criteria</p>
    </div>

    <!-- Action Buttons -->
    <div class="action-buttons">
        <div class="d-flex justify-content-between align-items-center flex-wrap">
            <div class="selection-counter">
                <span id="selectedCount">No stall selected</span>
            </div>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-secondary" onclick="clearSelection()" aria-label="Clear selection">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </button>
                <button type="button" class="btn btn-primary" id="proceedBtn" onclick="proceedToAudioManagement()"
                        disabled aria-label="Proceed to audio management">
                    <i class="bi bi-arrow-right me-1"></i>Proceed to Audio Management
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Sample stalls data
        const stallsData = [
            { id: 'A-001', zone: 'A', business: 'Golden Spoon Restaurant', status: 'occupied', size: 15, rent: 1200 },
            { id: 'A-002', zone: 'A', business: 'TechZone Electronics', status: 'occupied', size: 12, rent: 1000 },
            { id: 'A-003', zone: 'A', business: 'Fashion Hub', status: 'available', size: 20, rent: 1500 },
            { id: 'B-015', zone: 'B', business: 'Wellness Spa & Beauty', status: 'occupied', size: 8, rent: 800 },
            { id: 'B-016', zone: 'B', business: 'Fresh Mart Groceries', status: 'reserved', size: 10, rent: 950 },
            { id: 'C-042', zone: 'C', business: 'Vintage Bookstore', status: 'occupied', size: 18, rent: 1300 },
            { id: 'C-043', zone: 'C', business: 'Coffee Corner', status: 'available', size: 12, rent: 900 },
            { id: 'D-101', zone: 'D', business: 'Street Food Court', status: 'occupied', size: 25, rent: 1800 },
            { id: 'D-102', zone: 'D', business: 'Craft Market', status: 'available', size: 30, rent: 2000 },
            { id: 'A-004', zone: 'A', business: 'Juice Bar', status: 'occupied', size: 6, rent: 600 }
        ];

        let selectedStall = null;
        let filteredStalls = [...stallsData];

        // Get status badge color
        function getStatusBadgeColor(status) {
            const colors = {
                'occupied': 'success',
                'available': 'warning',
                'reserved': 'info',
                'maintenance': 'danger'
            };
            return colors[status] || 'secondary';
        }

        // Render stalls grid
        function renderStalls() {
            const grid = $('#stallsGrid');
            grid.empty();

            if (filteredStalls.length === 0) {
                $('#emptyState').show();
                return;
            }

            $('#emptyState').hide();

            filteredStalls.forEach(stall => {
                const statusBadgeColor = getStatusBadgeColor(stall.status);
                const isSelected = selectedStall && selectedStall.id === stall.id;

                const card = `
                    <div class="col-md-6 col-lg-4 mb-3">
                        <div class="card stall-card ${isSelected ? 'selected' : ''}" onclick="selectStall('${stall.id}')" role="button" tabindex="0"
                            onkeypress="if(event.key==='Enter') selectStall('${stall.id}')" aria-label="Select ${stall.business}">
                            <div class="stall-card-body">
                                <div class="stall-id">${stall.id}</div>
                                <div class="stall-name">${stall.business}</div>
                                <div class="stall-info">
                                    <i class="bi bi-geo-alt-fill stall-info-icon"></i>
                                    Zone ${stall.zone}
                                </div>
                                <div class="stall-info">
                                    <i class="bi bi-rulers stall-info-icon"></i>
                                    ${stall.size} sqm
                                </div>
                                <div class="stall-info">
                                    <i class="bi bi-currency-dollar stall-info-icon"></i>
                                    $${stall.rent}/month
                                </div>
                                <span class="badge bg-${statusBadgeColor} status-badge">
                                    ${stall.status.charAt(0).toUpperCase() + stall.status.slice(1)}
                                </span>
                            </div>
                        </div>
                    </div>
                `;
                grid.append(card);
            });
        }

        // Select a stall
        window.selectStall = function(stallId) {
            selectedStall = stallsData.find(s => s.id === stallId);
            $('#proceedBtn').prop('disabled', false);
            updateSelectionCounter();
            renderStalls();
        };

        // Clear selection
        window.clearSelection = function() {
            selectedStall = null;
            $('#proceedBtn').prop('disabled', true);
            updateSelectionCounter();
            renderStalls();
        };

        // Update selection counter
        function updateSelectionCounter() {
            if (selectedStall) {
                $('#selectedCount').text(`Selected: ${selectedStall.id} - ${selectedStall.business}`);
            } else {
                $('#selectedCount').text('No stall selected');
            }
        }

        // Proceed to audio management
        window.proceedToAudioManagement = function() {
            if (!selectedStall) {
                alert('Please select a stall first');
                return;
            }

            // Store selected stall in sessionStorage
            sessionStorage.setItem('selectedStall', JSON.stringify(selectedStall));

            // Redirect to audio management
            window.location.href = `/Pages/Business/AudioManagement.html?stallId=${selectedStall.id}&business=${encodeURIComponent(selectedStall.business)}`;
        };

        // Filter stalls
        function applyFilters() {
            const searchText = $('#stallSearch').val().toLowerCase();
            const zoneFilter = $('#zoneFilter').val();
            const statusFilter = $('#statusFilter').val();

            filteredStalls = stallsData.filter(stall => {
                const matchSearch = !searchText ||
                    stall.id.toLowerCase().includes(searchText) ||
                    stall.business.toLowerCase().includes(searchText);
                const matchZone = !zoneFilter || stall.zone === zoneFilter;
                const matchStatus = !statusFilter || stall.status === statusFilter;

                return matchSearch && matchZone && matchStatus;
            });

            renderStalls();
        }

        // Event listeners
        $('#stallSearch').on('keyup', applyFilters);
        $('#zoneFilter').on('change', applyFilters);
        $('#statusFilter').on('change', applyFilters);

        // Initial render
        $(document).ready(function() {
            renderStalls();
        });
    </script>
}