
@{
    ViewData["Title"] = "ContentAudioManagement";
}

@section Styles {
    <style>
        .audio-player-mock {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border-radius: 12px;
            padding: 20px;
            color: white;
        }
        .audio-waveform {
            height: 60px;
            background: linear-gradient(90deg, 
                transparent 0%, 
                rgba(59, 130, 246, 0.3) 10%,
                rgba(59, 130, 246, 0.6) 30%,
                rgba(59, 130, 246, 0.4) 50%,
                rgba(59, 130, 246, 0.7) 70%,
                rgba(59, 130, 246, 0.3) 90%,
                transparent 100%
            );
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
        }
        .audio-controls button {
            width: 50px;
            height: 50px;
            border-radius: 50%;
        }
        .language-badge {
            font-size: 0.75rem;
            padding: 4px 8px;
        }
        .content-preview {
            background: #f8f9fa;
            border-left: 4px solid #0d6efd;
            padding: 15px;
            border-radius: 0 8px 8px 0;
        }
        .tab-content-area {
            min-height: 400px;
        }
        .voice-option {
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .voice-option:hover {
            background-color: #e9ecef;
        }
        .voice-option.selected {
            background-color: #cfe2ff;
            border-color: #0d6efd;
        }
    </style>
}

<!-- Page Header -->
<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Pages/Home/Index.html">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Business</a></li>
            <li class="breadcrumb-item active" aria-current="page">Content &amp; Audio Management</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="bi bi-file-earmark-music me-2"></i>Content &amp; Audio Management</h1>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-clock-history me-1"></i>History
            </button>
            <button type="button" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add New
            </button>
        </div>
    </div>
</div>

<!-- Stall Selection -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <label for="stallContentSelect" class="form-label fw-bold">Select Stall to Manage</label>
                <select class="form-select" id="stallContentSelect">
                    <option value="">-- Select a Stall --</option>
                    <option value="A-001" selected>A-001 - Golden Spoon Restaurant</option>
                    <option value="A-002">A-002 - TechZone Electronics</option>
                    <option value="B-015">B-015 - Fashion Hub</option>
                    <option value="D-101">D-101 - Fresh Mart Groceries</option>
                </select>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1">Current Status</h6>
                        <span class="badge bg-success me-2">3 Languages</span>
                        <span class="badge bg-info">2 Audio Files</span>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">Last Updated</small>
                        <strong>Mar 15, 2026</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs" id="contentTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="text-tab" data-bs-toggle="tab" data-bs-target="#text-content" type="button" role="tab" aria-controls="text-content" aria-selected="true">
            <i class="bi bi-file-text me-1"></i>Text Content
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="audio-tab" data-bs-toggle="tab" data-bs-target="#audio-content" type="button" role="tab" aria-controls="audio-content" aria-selected="false">
            <i class="bi bi-soundwave me-1"></i>Audio Management
        </button>
    </li>
</ul>

<!-- Tab Content -->
<div class="tab-content tab-content-area" id="contentTabsContent">
    <!-- Text Content Tab -->
    <div class="tab-pane fade show active" id="text-content" role="tabpanel" aria-labelledby="text-tab">
        <div class="card border-top-0 rounded-top-0">
            <div class="card-body">
                <div class="row">
                    <!-- Language Selection & Editor -->
                    <div class="col-lg-8">
                        <form id="textContentForm" novalidate>
                            <!-- Language Dropdown -->
                            <div class="mb-3">
                                <label for="languageSelect" class="form-label">Select Language</label>
                                <select class="form-select" id="languageSelect" name="languageSelect">
                                    <option value="en" selected>English (EN)</option>
                                    <option value="zh">Chinese - Simplified (ZH)</option>
                                    <option value="zh-tw">Chinese - Traditional (ZH-TW)</option>
                                    <option value="ms">Malay (MS)</option>
                                    <option value="ta">Tamil (TA)</option>
                                    <option value="ja">Japanese (JA)</option>
                                    <option value="ko">Korean (KO)</option>
                                </select>
                            </div>

                            <!-- Content Title -->
                            <div class="mb-3">
                                <label for="contentTitle" class="form-label">Title</label>
                                <input type="text"
                                        class="form-control"
                                        id="contentTitle"
                                        name="contentTitle"
                                        value="Golden Spoon Restaurant"
                                        data-val="true"
                                        data-val-required="Title is required">
                                <span class="text-danger field-validation-valid" data-valmsg-for="contentTitle" data-valmsg-replace="true"></span>
                            </div>

                            <!-- Description Textarea -->
                            <div class="mb-3">
                                <label for="contentDescription" class="form-label">Description</label>
                                <textarea class="form-control"
                                            id="contentDescription"
                                            name="contentDescription"
                                            rows="6"
                                            data-val="true"
                                            data-val-required="Description is required"
                                            data-val-minlength="Description must be at least 20 characters"
                                            data-val-minlength-min="20">Welcome to Golden Spoon Restaurant! We serve authentic Asian fusion cuisine with a modern twist. Our signature dishes include handmade dumplings, aromatic curry laksa, and the famous crispy duck rice. Open daily from 10 AM to 10 PM. Visit us for a delightful culinary experience!</textarea>
                                <span class="text-danger field-validation-valid" data-valmsg-for="contentDescription" data-valmsg-replace="true"></span>
                                <div class="d-flex justify-content-between mt-1">
                                    <small class="text-muted">Minimum 20 characters</small>
                                    <small class="text-muted"><span id="charCount">285</span> characters</small>
                                </div>
                            </div>

                            <!-- Keywords -->
                            <div class="mb-3">
                                <label for="keywords" class="form-label">Keywords (comma separated)</label>
                                <input type="text"
                                        class="form-control"
                                        id="keywords"
                                        name="keywords"
                                        value="asian, restaurant, dumplings, laksa, duck rice"
                                        placeholder="e.g., food, restaurant, asian">
                            </div>

                            <!-- Save Button -->
                            <div class="d-flex justify-content-between">
                                <button type="button" class="btn btn-outline-secondary" id="translateBtn">
                                    <i class="bi bi-translate me-1"></i>Auto Translate
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-lg me-1"></i>Save Content
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Language Status Sidebar -->
                    <div class="col-lg-4">
                        <div class="card bg-light">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="bi bi-globe me-2"></i>Translation Status</h6>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush">
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                        <span><i class="bi bi-flag me-2"></i>English</span>
                                        <span class="badge bg-success">Complete</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                        <span><i class="bi bi-flag me-2"></i>Chinese (Simplified)</span>
                                        <span class="badge bg-success">Complete</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                        <span><i class="bi bi-flag me-2"></i>Malay</span>
                                        <span class="badge bg-success">Complete</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                        <span><i class="bi bi-flag me-2"></i>Tamil</span>
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent">
                                        <span><i class="bi bi-flag me-2"></i>Japanese</span>
                                        <span class="badge bg-secondary">Not Started</span>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Preview Card -->
                        <div class="card mt-3">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="bi bi-eye me-2"></i>Preview</h6>
                            </div>
                            <div class="card-body">
                                <div class="content-preview">
                                    <h6 id="previewTitle">Golden Spoon Restaurant</h6>
                                    <p class="small mb-0" id="previewDescription">Welcome to Golden Spoon Restaurant! We serve authentic Asian fusion cuisine...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Audio Management Tab -->
    <div class="tab-pane fade" id="audio-content" role="tabpanel" aria-labelledby="audio-tab">
        <div class="card border-top-0 rounded-top-0">
            <div class="card-body">
                <div class="row">
                    <!-- Audio Options -->
                    <div class="col-lg-6 mb-4">
                        <h5 class="mb-3"><i class="bi bi-upload me-2"></i>Upload Audio File</h5>
                        <form id="audioUploadForm" novalidate>
                            <div class="mb-3">
                                <label for="audioLanguage" class="form-label">Audio Language</label>
                                <select class="form-select" id="audioLanguage" name="audioLanguage">
                                    <option value="en" selected>English</option>
                                    <option value="zh">Chinese</option>
                                    <option value="ms">Malay</option>
                                    <option value="ta">Tamil</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label for="audioFile" class="form-label">Audio File</label>
                                <input type="file"
                                        class="form-control"
                                        id="audioFile"
                                        name="audioFile"
                                        accept="audio/*">
                                <small class="text-muted">Supported formats: MP3, WAV, OGG. Max size: 10MB</small>
                            </div>
                            <button type="submit" class="btn btn-outline-primary w-100">
                                <i class="bi bi-cloud-upload me-1"></i>Upload Audio
                            </button>
                        </form>

                        <hr class="my-4">

                        <h5 class="mb-3"><i class="bi bi-mic me-2"></i>Text-to-Speech Generator</h5>
                        <form id="ttsForm" novalidate>
                            <!-- TTS Text Input -->
                            <div class="mb-3">
                                <label for="ttsText" class="form-label">Text for Speech</label>
                                <textarea class="form-control"
                                            id="ttsText"
                                            name="ttsText"
                                            rows="4"
                                            placeholder="Enter text to convert to speech..."
                                            data-val="true"
                                            data-val-required="Please enter text to convert">Welcome to Golden Spoon Restaurant! We serve authentic Asian fusion cuisine with a modern twist.</textarea>
                                <span class="text-danger field-validation-valid" data-valmsg-for="ttsText" data-valmsg-replace="true"></span>
                            </div>

                            <!-- Voice Selection -->
                            <div class="mb-3">
                                <label class="form-label">Voice Type</label>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="card voice-option selected" data-voice="male" id="voiceMale">
                                            <div class="card-body text-center py-3">
                                                <i class="bi bi-person-fill fs-3 text-primary"></i>
                                                <div class="mt-1">Male</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="card voice-option" data-voice="female" id="voiceFemale">
                                            <div class="card-body text-center py-3">
                                                <i class="bi bi-person-fill fs-3 text-danger"></i>
                                                <div class="mt-1">Female</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" id="selectedVoice" name="selectedVoice" value="male">
                            </div>

                            <!-- Speed Control -->
                            <div class="mb-3">
                                <label for="speechSpeed" class="form-label">
                                    Speech Speed: <span id="speedValue">1.0x</span>
                                </label>
                                <input type="range"
                                        class="form-range"
                                        id="speechSpeed"
                                        name="speechSpeed"
                                        min="0.5"
                                        max="2"
                                        step="0.1"
                                        value="1">
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">0.5x (Slow)</small>
                                    <small class="text-muted">2.0x (Fast)</small>
                                </div>
                            </div>

                            <!-- Generate Button -->
                            <button type="button" class="btn btn-success w-100" id="generateTTS">
                                <i class="bi bi-soundwave me-1"></i>Generate Audio
                            </button>
                        </form>
                    </div>

                    <!-- Audio Preview & Management -->
                    <div class="col-lg-6">
                        <h5 class="mb-3"><i class="bi bi-play-circle me-2"></i>Audio Preview</h5>
                                
                        <!-- Audio Player Mock -->
                        <div class="audio-player-mock mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="badge bg-primary">English</span>
                                <small>Duration: 0:45</small>
                            </div>
                            <div class="audio-waveform">
                                <i class="bi bi-soundwave fs-1 text-white opacity-50"></i>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span id="currentTime">0:00</span>
                                <span id="totalTime">0:45</span>
                            </div>
                            <div class="progress mb-3" style="height: 6px;">
                                <div class="progress-bar bg-info" id="audioProgress" role="progressbar" style="width: 0%"></div>
                            </div>
                            <div class="audio-controls d-flex justify-content-center gap-3">
                                <button type="button" class="btn btn-outline-light" id="rewindBtn">
                                    <i class="bi bi-skip-backward-fill"></i>
                                </button>
                                <button type="button" class="btn btn-light" id="playPauseBtn">
                                    <i class="bi bi-play-fill fs-4"></i>
                                </button>
                                <button type="button" class="btn btn-outline-light" id="forwardBtn">
                                    <i class="bi bi-skip-forward-fill"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Existing Audio Files -->
                        <h6 class="mb-3"><i class="bi bi-folder me-2"></i>Existing Audio Files</h6>
                        <div class="list-group">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-file-earmark-music text-primary me-2"></i>
                                    <strong>intro_en.mp3</strong>
                                    <span class="badge language-badge bg-secondary ms-2">English</span>
                                </div>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary" title="Play"><i class="bi bi-play"></i></button>
                                    <button type="button" class="btn btn-outline-info" title="Download"><i class="bi bi-download"></i></button>
                                    <button type="button" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <i class="bi bi-file-earmark-music text-primary me-2"></i>
                                    <strong>intro_zh.mp3</strong>
                                    <span class="badge language-badge bg-danger ms-2">Chinese</span>
                                </div>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-primary" title="Play"><i class="bi bi-play"></i></button>
                                    <button type="button" class="btn btn-outline-info" title="Download"><i class="bi bi-download"></i></button>
                                    <button type="button" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>
                        </div>

                        <!-- Generation Status -->
                        <div class="alert alert-info mt-3 d-none" id="generationStatus">
                            <div class="d-flex align-items-center">
                                <div class="spinner-border spinner-border-sm me-2" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <span>Generating audio... Please wait.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Character count for description
            $('#contentDescription').on('input', function() {
                var count = $(this).val().length;
                $('#charCount').text(count);
                
                // Update preview
                var text = $(this).val();
                $('#previewDescription').text(text.substring(0, 100) + (text.length > 100 ? '...' : ''));
            });

            // Update title preview
            $('#contentTitle').on('input', function() {
                $('#previewTitle').text($(this).val() || 'Title');
            });

            // Text content form submission
            $('#textContentForm').on('submit', function(e) {
                e.preventDefault();
                if ($(this).valid()) {
                    showToast('Content saved successfully!', 'success');
                }
            });

            // Auto translate button
            $('#translateBtn').on('click', function() {
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Translating...');
                
                setTimeout(function() {
                    btn.prop('disabled', false).html('<i class="bi bi-translate me-1"></i>Auto Translate');
                    showToast('Translation completed for selected language!', 'success');
                }, 2000);
            });

            // Voice type selection
            $('.voice-option').on('click', function() {
                $('.voice-option').removeClass('selected');
                $(this).addClass('selected');
                $('#selectedVoice').val($(this).data('voice'));
            });

            // Speech speed slider
            $('#speechSpeed').on('input', function() {
                var val = parseFloat($(this).val()).toFixed(1);
                $('#speedValue').text(val + 'x');
            });

            // Generate TTS button
            $('#generateTTS').on('click', function() {
                var text = $('#ttsText').val();
                if (!text.trim()) {
                    showToast('Please enter text to convert!', 'warning');
                    return;
                }

                var statusDiv = $('#generationStatus');
                var btn = $(this);
                
                btn.prop('disabled', true);
                statusDiv.removeClass('d-none');

                // Simulate generation
                setTimeout(function() {
                    statusDiv.addClass('d-none');
                    btn.prop('disabled', false);
                    showToast('Audio generated successfully!', 'success');
                    
                    // Reset progress bar
                    $('#audioProgress').css('width', '0%');
                    $('#currentTime').text('0:00');
                }, 3000);
            });

            // Audio player controls (mock)
            var isPlaying = false;
            var progress = 0;
            var progressInterval;

            $('#playPauseBtn').on('click', function() {
                var icon = $(this).find('i');
                
                if (isPlaying) {
                    isPlaying = false;
                    icon.removeClass('bi-pause-fill').addClass('bi-play-fill');
                    clearInterval(progressInterval);
                } else {
                    isPlaying = true;
                    icon.removeClass('bi-play-fill').addClass('bi-pause-fill');
                    
                    progressInterval = setInterval(function() {
                        progress += 2;
                        if (progress >= 100) {
                            progress = 0;
                            isPlaying = false;
                            icon.removeClass('bi-pause-fill').addClass('bi-play-fill');
                            clearInterval(progressInterval);
                        }
                        $('#audioProgress').css('width', progress + '%');
                        
                        // Update time
                        var seconds = Math.floor((progress / 100) * 45);
                        var timeStr = '0:' + (seconds < 10 ? '0' : '') + seconds;
                        $('#currentTime').text(timeStr);
                    }, 500);
                }
            });

            $('#rewindBtn').on('click', function() {
                progress = Math.max(0, progress - 10);
                $('#audioProgress').css('width', progress + '%');
            });

            $('#forwardBtn').on('click', function() {
                progress = Math.min(100, progress + 10);
                $('#audioProgress').css('width', progress + '%');
            });

            // Audio upload form
            $('#audioUploadForm').on('submit', function(e) {
                e.preventDefault();
                var file = $('#audioFile').val();
                if (!file) {
                    showToast('Please select an audio file!', 'warning');
                    return;
                }
                showToast('Audio file uploaded successfully!', 'success');
                $('#audioFile').val('');
            });

            // Parse unobtrusive validation
            $.validator.unobtrusive.parse('#textContentForm');
            $.validator.unobtrusive.parse('#ttsForm');
        });

        // Toast notification function
        function showToast(message, type) {
            type = type || 'info';
            var bgClass = type === 'success' ? 'bg-success' : (type === 'warning' ? 'bg-warning text-dark' : 'bg-info');
            var iconClass = type === 'success' ? 'bi-check-circle' : (type === 'warning' ? 'bi-exclamation-circle' : 'bi-info-circle');
            
            var toast = $('<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">' +
                '<div class="toast show ' + bgClass + ' text-white" role="alert">' +
                '<div class="toast-body d-flex align-items-center">' +
                '<i class="bi ' + iconClass + ' me-2"></i>' + message +
                '</div></div></div>');
            
            $('body').append(toast);
            setTimeout(function() {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }
    </script>
}