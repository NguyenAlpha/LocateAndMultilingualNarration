
@{
    ViewData["Title"] = "StallManagement";
}

<!-- Page Header -->
<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Pages/Home/Index.html">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Stall Management</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="bi bi-shop me-2"></i>Stall Management</h1>
        <div class="btn-group">
            <a href="/Pages/Management/StallLocationMap.html" class="btn btn-outline-primary">
                <i class="bi bi-map me-1"></i>View Map
            </a>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStallModal">
                <i class="bi bi-plus-lg me-1"></i>Add Stall
            </button>
        </div>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card stats-card h-100">
            <div class="card-body text-center">
                <h3 class="stats-number text-primary">1,452</h3>
                <small class="text-muted">Total Stalls</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card stats-card success h-100">
            <div class="card-body text-center">
                <h3 class="stats-number text-success">1,257</h3>
                <small class="text-muted">Occupied</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card stats-card warning h-100">
            <div class="card-body text-center">
                <h3 class="stats-number text-warning">172</h3>
                <small class="text-muted">Available</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card stats-card danger h-100">
            <div class="card-body text-center">
                <h3 class="stats-number text-danger">23</h3>
                <small class="text-muted">Under Maintenance</small>
            </div>
        </div>
    </div>
</div>

<!-- Search/Filter -->
<div class="search-filter-bar">
    <div class="row g-3">
        <div class="col-md-3">
            <label for="stallSearch" class="form-label visually-hidden">Search stalls</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control table-search" id="stallSearch" placeholder="Search stalls...">
            </div>
        </div>
        <div class="col-md-2">
            <label for="zoneFilter" class="form-label visually-hidden">Filter by zone</label>
            <select class="form-select" id="zoneFilter" aria-label="Filter by zone">
                <option value="">All Zones</option>
                <option value="A">Zone A - Main Hall</option>
                <option value="B">Zone B - East Wing</option>
                <option value="C">Zone C - West Wing</option>
                <option value="D">Zone D - Outdoor</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="stallStatusFilter" class="form-label visually-hidden">Filter by status</label>
            <select class="form-select status-filter" id="stallStatusFilter" aria-label="Filter by status">
                <option value="">All Status</option>
                <option value="occupied">Occupied</option>
                <option value="available">Available</option>
                <option value="reserved">Reserved</option>
                <option value="maintenance">Maintenance</option>
            </select>
        </div>
        <div class="col-md-2">
            <label for="sizeFilter" class="form-label visually-hidden">Filter by size</label>
            <select class="form-select" id="sizeFilter" aria-label="Filter by size">
                <option value="">All Sizes</option>
                <option value="small">Small (1-10 sqm)</option>
                <option value="medium">Medium (11-25 sqm)</option>
                <option value="large">Large (26+ sqm)</option>
            </select>
        </div>
        <div class="col-md-3">
            <div class="btn-group w-100">
                <button class="btn btn-outline-secondary" type="button" onclick="exportTableToCSV('stallTable', 'stalls.csv')">
                    <i class="bi bi-download me-1"></i>Export
                </button>
                <button class="btn btn-outline-secondary" type="button">
                    <i class="bi bi-funnel me-1"></i>Filters
                </button>
            </div>
        </div>
    </div>
</div>

