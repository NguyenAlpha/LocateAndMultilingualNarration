<!-- Add Stall Modal -->
<div class="modal fade" id="addStallModal" tabindex="-1" aria-labelledby="addStallModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addStallModalLabel"><i class="bi bi-shop me-2"></i>Add New Stall</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addStallForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="stallId" class="form-label">Stall ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="stallId" name="StallId"
                               data-val="true"
                               data-val-required="Stall ID is required"
                               placeholder="e.g., A-001">
                        <span class="field-validation-valid" data-valmsg-for="StallId" data-valmsg-replace="true"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="stallZone" class="form-label">Zone <span class="text-danger">*</span></label>
                            <select class="form-select" id="stallZone" name="Zone"
                                    data-val="true"
                                    data-val-required="Please select a zone">
                                <option value="">Select zone</option>
                                <option value="A">Zone A - Main Hall</option>
                                <option value="B">Zone B - East Wing</option>
                                <option value="C">Zone C - West Wing</option>
                                <option value="D">Zone D - Outdoor</option>
                            </select>
                            <span class="field-validation-valid" data-valmsg-for="Zone" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="stallSize" class="form-label">Size (sqm) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="stallSize" name="Size"
                                   data-val="true"
                                   data-val-required="Size is required"
                                   data-val-range="Size must be between 1 and 500"
                                   data-val-range-min="1"
                                   data-val-range-max="500"
                                   placeholder="Enter size">
                            <span class="field-validation-valid" data-valmsg-for="Size" data-valmsg-replace="true"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="monthlyRent" class="form-label">Monthly Rent ($) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="monthlyRent" name="MonthlyRent"
                               data-val="true"
                               data-val-required="Monthly rent is required"
                               data-val-range="Rent must be between 100 and 50000"
                               data-val-range-min="100"
                               data-val-range-max="50000"
                               placeholder="Enter monthly rent">
                        <span class="field-validation-valid" data-valmsg-for="MonthlyRent" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label for="stallStatus" class="form-label">Status</label>
                        <select class="form-select" id="stallStatus" name="Status">
                            <option value="available">Available</option>
                            <option value="reserved">Reserved</option>
                            <option value="maintenance">Under Maintenance</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="stallDescription" class="form-label">Notes</label>
                        <textarea class="form-control" id="stallDescription" name="Notes" rows="2" placeholder="Additional notes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Stall</button>
                </div>
            </form>
        </div>
    </div>
</div>
