
@{
    ViewData["Title"] = "StallLocationMap";
}

@section Styles {
    <style>
        #map {
            height: 450px;
            background: linear-gradient(135deg, #e8f4f8 0%, #d1e8ff 100%);
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        #map::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                linear-gradient(rgba(200, 220, 240, 0.3) 1px, transparent 1px),
                linear-gradient(90deg, rgba(200, 220, 240, 0.3) 1px, transparent 1px);
            background-size: 40px 40px;
        }
        .map-placeholder-icon {
            font-size: 4rem;
            color: #6c757d;
            z-index: 1;
        }
        .map-marker {
            position: absolute;
            font-size: 2.5rem;
            color: #dc3545;
            z-index: 2;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .map-marker:hover {
            transform: scale(1.2);
        }
        .map-info-badge {
            position: absolute;
            bottom: 10px;
            left: 10px;
            z-index: 3;
        }
        .location-card {
            border-left: 4px solid #0d6efd;
        }
        .coordinate-display {
            font-family: monospace;
            background: #f8f9fa;
            padding: 8px 12px;
            border-radius: 4px;
            font-size: 0.9rem;
        }
    </style>
}

<!-- Page Header -->
<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Pages/Home/Index.html">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Business</a></li>
            <li class="breadcrumb-item active" aria-current="page">Stall Location Map</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="bi bi-geo-alt me-2"></i>Stall Location Map</h1>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-secondary" id="toggleSatellite">
                <i class="bi bi-layers me-1"></i>Satellite View
            </button>
            <button type="button" class="btn btn-outline-primary" id="centerMap">
                <i class="bi bi-bullseye me-1"></i>Center Map
            </button>
        </div>
    </div>
</div>

<!-- Alert -->
<div class="alert alert-info alert-dismissible fade show" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Google Maps Integration Placeholder:</strong> This is a mock interface. In production, integrate with Google Maps API for full functionality.
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

<!-- Map and Form Layout -->
<div class="row">
    <!-- Map Section -->
    <div class="col-lg-7 mb-4">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-map me-2"></i>Location Map</h5>
                <span class="badge bg-secondary">Click to select location</span>
            </div>
            <div class="card-body p-0">
                <div id="map" onclick="simulateMapClick(event)">
                    <i class="bi bi-geo-alt-fill map-placeholder-icon"></i>
                    <p class="text-muted mt-2 z-1">Click anywhere on the map to select a location</p>
                    <i class="bi bi-geo-alt-fill map-marker" id="mapMarker" style="display: none;"></i>
                    <div class="map-info-badge">
                        <span class="badge bg-dark">
                            <i class="bi bi-zoom-in me-1"></i>Zoom: 15
                        </span>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-4">
                        <small class="text-muted d-block">Total Stalls</small>
                        <strong class="text-primary">1,452</strong>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">In This Area</small>
                        <strong class="text-success">23</strong>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">Available</small>
                        <strong class="text-warning">5</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Location Form Section -->
    <div class="col-lg-5">
        <div class="card shadow-sm location-card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-pin-map me-2"></i>Location Details</h5>
            </div>
            <div class="card-body">
                <form id="locationForm" novalidate>
                    <!-- Stall Selection -->
                    <div class="mb-3">
                        <label for="stallSelect" class="form-label">Select Stall</label>
                        <select class="form-select" id="stallSelect" name="stallSelect">
                            <option value="">-- Select a Stall --</option>
                            <option value="A-001">A-001 - Golden Spoon Restaurant</option>
                            <option value="A-002">A-002 - TechZone Electronics</option>
                            <option value="A-003">A-003 - Available</option>
                            <option value="B-015">B-015 - Fashion Hub</option>
                            <option value="B-016">B-016 - Reserved</option>
                        </select>
                    </div>

                    <!-- Coordinates Display -->
                    <div class="mb-3">
                        <label class="form-label">Selected Coordinates</label>
                        <div class="coordinate-display mb-2" id="coordinateDisplay">
                            <i class="bi bi-crosshair me-2"></i>Click on map to select location
                        </div>
                    </div>

                    <!-- Latitude -->
                    <div class="mb-3">
                        <label for="latitude" class="form-label">Latitude</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-compass"></i></span>
                            <input type="text" 
                                    class="form-control" 
                                    id="latitude" 
                                    name="latitude" 
                                    placeholder="0.000000"
                                    readonly>
                        </div>
                    </div>

                    <!-- Longitude -->
                    <div class="mb-3">
                        <label for="longitude" class="form-label">Longitude</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-compass"></i></span>
                            <input type="text" 
                                    class="form-control" 
                                    id="longitude" 
                                    name="longitude" 
                                    placeholder="0.000000"
                                    readonly>
                        </div>
                    </div>

                    <!-- Radius -->
                    <div class="mb-3">
                        <label for="radius" class="form-label">Service Radius (meters)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-circle"></i></span>
                            <input type="number" 
                                    class="form-control" 
                                    id="radius" 
                                    name="radius" 
                                    placeholder="Enter radius"
                                    min="10"
                                    max="5000"
                                    value="100"
                                    data-val="true"
                                    data-val-range="Radius must be between 10 and 5000 meters"
                                    data-val-range-min="10"
                                    data-val-range-max="5000">
                            <span class="input-group-text">m</span>
                        </div>
                        <span class="text-danger field-validation-valid" data-valmsg-for="radius" data-valmsg-replace="true"></span>
                        <small class="text-muted">Range: 10 - 5000 meters</small>
                    </div>

                    <!-- Address Preview -->
                    <div class="mb-3">
                        <label class="form-label">Address (Auto-detected)</label>
                        <textarea class="form-control" id="addressPreview" rows="2" readonly placeholder="Address will appear after selecting location"></textarea>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-grid gap-2">
                        <button type="button" class="btn btn-outline-primary" id="pickLocationBtn">
                            <i class="bi bi-cursor me-1"></i>Pick Location on Map
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="useCurrentLocation">
                            <i class="bi bi-crosshair me-1"></i>Use My Current Location
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save Location
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="card mt-4 shadow-sm">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-printer me-1"></i>Print Map
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-success">
                        <i class="bi bi-share me-1"></i>Share Location
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-warning">
                        <i class="bi bi-arrow-repeat me-1"></i>Reset All
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Mock base coordinates (Singapore)
        var baseLatitude = 1.3521;
        var baseLongitude = 103.8198;

        // Simulate map click
        function simulateMapClick(event) {
            var mapElement = document.getElementById('map');
            var rect = mapElement.getBoundingClientRect();
            var x = event.clientX - rect.left;
            var y = event.clientY - rect.top;
            
            // Convert click position to mock coordinates
            var latOffset = ((rect.height / 2) - y) / rect.height * 0.01;
            var lngOffset = (x - (rect.width / 2)) / rect.width * 0.01;
            
            var newLat = (baseLatitude + latOffset).toFixed(6);
            var newLng = (baseLongitude + lngOffset).toFixed(6);
            
            updateLocation(newLat, newLng, x, y);
        }

        // Update location fields
        function updateLocation(lat, lng, markerX, markerY) {
            $('#latitude').val(lat);
            $('#longitude').val(lng);
            $('#coordinateDisplay').html('<i class="bi bi-geo-alt-fill text-danger me-2"></i>Lat: ' + lat + ', Lng: ' + lng);
            
            // Mock address
            var mockAddresses = [
                '123 Enterprise Plaza, Block A, Singapore 123456',
                '456 Business Center, Level 2, Singapore 234567',
                '789 Market Street, Unit 15, Singapore 345678'
            ];
            var randomAddress = mockAddresses[Math.floor(Math.random() * mockAddresses.length)];
            $('#addressPreview').val(randomAddress);
            
            // Show and position marker
            var marker = document.getElementById('mapMarker');
            var mapElement = document.getElementById('map');
            marker.style.display = 'block';
            marker.style.left = (markerX - 15) + 'px';
            marker.style.top = (markerY - 35) + 'px';
            
            // Animation
            marker.style.animation = 'none';
            marker.offsetHeight; // Trigger reflow
            marker.style.animation = 'bounce 0.5s ease';
        }

        $(document).ready(function() {
            // Pick Location button
            $('#pickLocationBtn').on('click', function() {
                // Simulate a random location pick
                var randomLat = (baseLatitude + (Math.random() - 0.5) * 0.01).toFixed(6);
                var randomLng = (baseLongitude + (Math.random() - 0.5) * 0.01).toFixed(6);
                
                var mapElement = document.getElementById('map');
                var rect = mapElement.getBoundingClientRect();
                var randomX = rect.width / 2 + (Math.random() - 0.5) * rect.width * 0.6;
                var randomY = rect.height / 2 + (Math.random() - 0.5) * rect.height * 0.6;
                
                updateLocation(randomLat, randomLng, randomX, randomY);
                
                // Show toast notification
                showToast('Location picked successfully!');
            });

            // Use Current Location button
            $('#useCurrentLocation').on('click', function() {
                // Simulate getting current location
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Getting location...');
                
                setTimeout(function() {
                    var currentLat = (baseLatitude + (Math.random() - 0.5) * 0.005).toFixed(6);
                    var currentLng = (baseLongitude + (Math.random() - 0.5) * 0.005).toFixed(6);
                    
                    var mapElement = document.getElementById('map');
                    var rect = mapElement.getBoundingClientRect();
                    
                    updateLocation(currentLat, currentLng, rect.width / 2, rect.height / 2);
                    
                    btn.prop('disabled', false).html('<i class="bi bi-crosshair me-1"></i>Use My Current Location');
                    showToast('Current location detected!');
                }, 1500);
            });

            // Center Map button
            $('#centerMap').on('click', function() {
                var mapElement = document.getElementById('map');
                var rect = mapElement.getBoundingClientRect();
                updateLocation(baseLatitude.toFixed(6), baseLongitude.toFixed(6), rect.width / 2, rect.height / 2);
                showToast('Map centered!');
            });

            // Form submission
            $('#locationForm').on('submit', function(e) {
                e.preventDefault();
                
                var lat = $('#latitude').val();
                var lng = $('#longitude').val();
                
                if (!lat || !lng) {
                    showToast('Please select a location on the map first!', 'warning');
                    return;
                }
                
                showToast('Location saved successfully!', 'success');
            });

            // Parse unobtrusive validation
            $.validator.unobtrusive.parse('#locationForm');
        });

        // Simple toast notification
        function showToast(message, type) {
            type = type || 'info';
            var bgClass = type === 'success' ? 'bg-success' : (type === 'warning' ? 'bg-warning text-dark' : 'bg-info');
            
            var toast = $('<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">' +
                '<div class="toast show ' + bgClass + ' text-white" role="alert">' +
                '<div class="toast-body d-flex align-items-center">' +
                '<i class="bi bi-check-circle me-2"></i>' + message +
                '</div></div></div>');
            
            $('body').append(toast);
            setTimeout(function() {
                toast.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }

        // Add bounce animation
        var style = document.createElement('style');
        style.textContent = '@@keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }';
        document.head.appendChild(style);
    </script>
}