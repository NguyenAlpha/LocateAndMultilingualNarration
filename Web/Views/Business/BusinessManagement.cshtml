@model Web.Models.BusinessManagementViewModel
@{
    ViewData["Title"] = "Business Management";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<!-- Page Header -->
<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a href="#">Management</a></li>
            <li class="breadcrumb-item active" aria-current="page">Business Management</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="bi bi-building me-2"></i>Business Management</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addBusinessModal">
            <i class="bi bi-plus-lg me-1"></i>Add New Business
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success" role="alert">
        @Model.SuccessMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

<!-- Search/Filter -->
<div class="search-filter-bar">
    <form method="get" asp-action="Index" class="row g-3">
        <div class="col-md-4">
            <label for="businessSearch" class="form-label visually-hidden">Search businesses</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control table-search" id="businessSearch" name="search"
                       value="@Model.Search" placeholder="Search businesses...">
            </div>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" type="submit">
                <i class="bi bi-search me-1"></i>Search
            </button>
        </div>
        <div class="col-md-2">
            <a class="btn btn-outline-secondary w-100" asp-action="Index">
                <i class="bi bi-x-circle me-1"></i>Reset
            </a>
        </div>
    </form>
</div>

<!-- Business Table -->
<div class="table-container">
    <div class="table-responsive">
        <table class="table table-hover" id="businessTable" aria-label="Business list">
            <thead>
                <tr>
                    <th scope="col" class="sortable">Business Name</th>
                    <th scope="col" class="sortable">Tax Code</th>
                    <th scope="col" class="sortable">Contact Email</th>
                    <th scope="col" class="sortable">Contact Phone</th>
                    <th scope="col" class="sortable">Status</th>
                    <th scope="col" class="sortable">Created At</th>
                    <th scope="col" class="no-export">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Chưa có business nào.</td>
                    </tr>
                }
                else
                {
                    foreach (var business in Model.Items)
                    {
                        var statusClass = business.IsActive ? "success" : "secondary";
                        var statusText = business.IsActive ? "Active" : "Inactive";
                        <tr>
                            <td>
                                <strong>@business.Name</strong>
                                <small class="d-block text-muted">ID: @business.Id</small>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(business.TaxCode) ? "-" : business.TaxCode)</td>
                            <td>@(string.IsNullOrWhiteSpace(business.ContactEmail) ? "-" : business.ContactEmail)</td>
                            <td>@(string.IsNullOrWhiteSpace(business.ContactPhone) ? "-" : business.ContactPhone)</td>
                            <td><span class="badge bg-@statusClass">@statusText</span></td>
                            <td>@business.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="btn-group">
                                    <button type="button" class="btn btn-sm btn-outline-primary btn-action"
                                            data-bs-toggle="tooltip" title="Edit"
                                            data-id="@business.Id"
                                            data-name="@business.Name"
                                            data-taxcode="@business.TaxCode"
                                            data-email="@business.ContactEmail"
                                            data-phone="@business.ContactPhone"
                                            data-active="@business.IsActive"
                                            onclick="openEditModal(this)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-info btn-action"
                                            data-bs-toggle="tooltip" title="View Details"
                                            data-id="@business.Id"
                                            data-name="@business.Name"
                                            data-taxcode="@business.TaxCode"
                                            data-email="@business.ContactEmail"
                                            data-phone="@business.ContactPhone"
                                            data-active="@business.IsActive"
                                            data-created="@business.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                            onclick="openShowModal(this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                    <form asp-action="Deactivate" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@business.Id" />
                                        <input type="hidden" name="page" value="@Model.Page" />
                                        <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                        <input type="hidden" name="search" value="@Model.Search" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger btn-action"
                                                data-bs-toggle="tooltip" title="Deactivate"
                                                onclick="return confirm('Bạn chắc chắn muốn vô hiệu hóa business này?');">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted">
            Showing @startIndex-@endIndex of @Model.TotalCount businesses
        </div>
        <nav aria-label="Business list pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>

<!-- Add Business Modal -->
<div class="modal fade" id="addBusinessModal" tabindex="-1" aria-labelledby="addBusinessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addBusinessModalLabel"><i class="bi bi-building-add me-2"></i>Add New Business</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.Name" class="form-label">Business Name <span class="text-danger">*</span></label>
                            <input asp-for="Create.Name" class="form-control" placeholder="Enter business name">
                            <span asp-validation-for="Create.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.TaxCode" class="form-label">Tax Code</label>
                            <input asp-for="Create.TaxCode" class="form-control" placeholder="Enter tax code">
                            <span asp-validation-for="Create.TaxCode" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="Create.ContactEmail" class="form-control" placeholder="Enter contact email">
                            <span asp-validation-for="Create.ContactEmail" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Create.ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="Create.ContactPhone" class="form-control" placeholder="Enter contact phone">
                            <span asp-validation-for="Create.ContactPhone" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-check">
                        <input asp-for="Create.IsActive" class="form-check-input" />
                        <label asp-for="Create.IsActive" class="form-check-label">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create Business
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Modal -->
<div class="modal fade" id="editBusinessModal" tabindex="-1" aria-labelledby="editBusinessModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBusinessModalLabel"><i class="bi bi-pencil-square me-2"></i>Edit Business</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="page" value="@Model.Page" />
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input asp-for="Edit.Id" type="hidden" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.Name" class="form-label">Business Name <span class="text-danger">*</span></label>
                            <input asp-for="Edit.Name" id="editBusinessName" class="form-control" placeholder="Enter business name">
                            <span asp-validation-for="Edit.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.TaxCode" class="form-label">Tax Code</label>
                            <input asp-for="Edit.TaxCode" id="editTaxCode" class="form-control" placeholder="Enter tax code">
                            <span asp-validation-for="Edit.TaxCode" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.ContactEmail" class="form-label">Contact Email</label>
                            <input asp-for="Edit.ContactEmail" id="editContactEmail" class="form-control" placeholder="Enter contact email">
                            <span asp-validation-for="Edit.ContactEmail" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.ContactPhone" class="form-label">Contact Phone</label>
                            <input asp-for="Edit.ContactPhone" id="editContactPhone" class="form-control" placeholder="Enter contact phone">
                            <span asp-validation-for="Edit.ContactPhone" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Edit.IsActive" class="form-label">Status</label>
                            <select asp-for="Edit.IsActive" class="form-select" id="editBusinessStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Show Business Details Modal -->
<div class="modal fade" id="showBusinessModal" tabindex="-1" aria-labelledby="showBusinessModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="showBusinessModalLabel"><i class="bi bi-eye me-2"></i>Business Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Business Name:</strong></p>
                        <p id="showBusinessName" class="text-muted">-</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Business ID:</strong></p>
                        <p id="showBusinessId" class="text-muted">-</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Tax Code:</strong></p>
                        <p id="showTaxCode" class="text-muted">-</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Status:</strong></p>
                        <p id="showBusinessStatus" class="text-muted">-</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Contact Email:</strong></p>
                        <p id="showContactEmail" class="text-muted">-</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Contact Phone:</strong></p>
                        <p id="showContactPhone" class="text-muted">-</p>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Created At:</strong></p>
                        <p id="showCreatedAt" class="text-muted">-</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function openEditModal(button) {
            const $button = $(button);
            $('#editBusinessName').val($button.data('name'));
            $('#editTaxCode').val($button.data('taxcode'));
            $('#editContactEmail').val($button.data('email'));
            $('#editContactPhone').val($button.data('phone'));
            $('#editBusinessStatus').val(String($button.data('active')).toLowerCase());
            $('input[name="Edit.Id"]').val($button.data('id'));

            const editModal = new bootstrap.Modal(document.getElementById('editBusinessModal'));
            editModal.show();
        }

        function openShowModal(button) {
            const $button = $(button);
            const isActive = String($button.data('active')).toLowerCase() === 'true';
            $('#showBusinessName').text($button.data('name'));
            $('#showBusinessId').text($button.data('id'));
            $('#showTaxCode').text($button.data('taxcode') || '-');
            $('#showContactEmail').text($button.data('email') || '-');
            $('#showContactPhone').text($button.data('phone') || '-');
            $('#showCreatedAt').text($button.data('created') || '-');
            $('#showBusinessStatus').html(`<span class="badge bg-${isActive ? 'success' : 'secondary'}">${isActive ? 'Active' : 'Inactive'}</span>`);

            const showModal = new bootstrap.Modal(document.getElementById('showBusinessModal'));
            showModal.show();
        }

        $(document).ready(function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            @if (Model.ShowCreateModal)
            {
                <text>
                new bootstrap.Modal(document.getElementById('addBusinessModal')).show();
                </text>
            }

            @if (Model.ShowEditModal)
            {
                <text>
                new bootstrap.Modal(document.getElementById('editBusinessModal')).show();
                </text>
            }
        });
    </script>
}
