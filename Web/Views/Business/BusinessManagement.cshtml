<!-- Add Business Modal -->
<div class="modal fade" id="addBusinessModal" tabindex="-1" aria-labelledby="addBusinessModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addBusinessModalLabel"><i class="bi bi-building-add me-2"></i>Add New Business</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addBusinessForm">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="businessName" class="form-label">Business Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="businessName" name="BusinessName"
                                   data-val="true"
                                   data-val-required="Business name is required"
                                   data-val-length="Business name must be between 2 and 100 characters"
                                   data-val-length-min="2"
                                   data-val-length-max="100"
                                   placeholder="Enter business name">
                            <span class="field-validation-valid" data-valmsg-for="BusinessName" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="businessCategory" class="form-label">Category <span class="text-danger">*</span></label>
                            <select class="form-select" id="businessCategory" name="Category"
                                    data-val="true"
                                    data-val-required="Please select a category">
                                <option value="">Select category</option>
                                <option value="food">Food & Beverage</option>
                                <option value="retail">Retail</option>
                                <option value="services">Services</option>
                                <option value="entertainment">Entertainment</option>
                                <option value="other">Other</option>
                            </select>
                            <span class="field-validation-valid" data-valmsg-for="Category" data-valmsg-replace="true"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="ownerName" class="form-label">Owner Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="ownerName" name="OwnerName"
                                   data-val="true"
                                   data-val-required="Owner name is required"
                                   placeholder="Enter owner name">
                            <span class="field-validation-valid" data-valmsg-for="OwnerName" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="ownerEmail" class="form-label">Owner Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="ownerEmail" name="OwnerEmail"
                                   data-val="true"
                                   data-val-required="Email is required"
                                   data-val-email="Please enter a valid email address"
                                   placeholder="Enter owner email">
                            <span class="field-validation-valid" data-valmsg-for="OwnerEmail" data-valmsg-replace="true"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="phone" class="form-label">Phone Number</label>
                            <input type="tel" class="form-control" id="phone" name="Phone"
                                   data-val="true"
                                   data-val-regex="Please enter a valid phone number"
                                   data-val-regex-pattern="^[\d\s\-\+\(\)]+$"
                                   placeholder="Enter phone number">
                            <span class="field-validation-valid" data-valmsg-for="Phone" data-valmsg-replace="true"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="registrationNumber" class="form-label">Registration Number</label>
                            <input type="text" class="form-control" id="registrationNumber" name="RegistrationNumber"
                                   placeholder="Enter registration number">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="address" class="form-label">Business Address <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="address" name="Address" rows="2"
                                  data-val="true"
                                  data-val-required="Address is required"
                                  placeholder="Enter business address"></textarea>
                        <span class="field-validation-valid" data-valmsg-for="Address" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="Description" rows="3"
                                  data-val="true"
                                  data-val-length="Description must be less than 500 characters"
                                  data-val-length-max="500"
                                  placeholder="Brief description of the business"></textarea>
                        <span class="field-validation-valid" data-valmsg-for="Description" data-valmsg-replace="true"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="businessStatus" class="form-label">Status</label>
                            <select class="form-select" id="businessStatus" name="Status">
                                <option value="pending">Pending Approval</option>
                                <option value="active">Active</option>
                                <option value="suspended">Suspended</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label d-block">Options</label>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" id="featured" name="Featured">
                                <label class="form-check-label" for="featured">Featured Business</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-lg me-1"></i>Create Business
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
