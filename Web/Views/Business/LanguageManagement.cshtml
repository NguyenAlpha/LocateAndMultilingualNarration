        <!-- Default Language Settings -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Settings</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="defaultLanguage" class="form-label">Default Language</label>
                    <select class="form-select" id="defaultLanguage">
                        <option value="en-US" selected>English (en-US)</option>
                        <option value="es-ES">Spanish (es-ES)</option>
                        <option value="fr-FR">French (fr-FR)</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label for="fallbackLanguage" class="form-label">Fallback Language</label>
                    <select class="form-select" id="fallbackLanguage">
                        <option value="en-US" selected>English (en-US)</option>
                    </select>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" id="autoDetect" checked>
                    <label class="form-check-label" for="autoDetect">Auto-detect user language</label>
                </div>
                <button class="btn btn-primary w-100">Save Settings</button>
            </div>
        </div>
