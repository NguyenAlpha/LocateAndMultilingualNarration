            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary text-start">
                        <i class="bi bi-upload me-2"></i>Import Translations
                    </button>
                    <button class="btn btn-outline-primary text-start">
                        <i class="bi bi-download me-2"></i>Export All Translations
                    </button>
                    <button class="btn btn-outline-warning text-start">
                        <i class="bi bi-robot me-2"></i>Auto-Translate Missing
                    </button>
