<!-- Add Language Modal -->
<div class="modal fade" id="addLanguageModal" tabindex="-1" aria-labelledby="addLanguageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addLanguageModalLabel"><i class="bi bi-translate me-2"></i>Add New Language</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="addLanguageForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="languageName" class="form-label">Language Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="languageName" name="LanguageName"
                               data-val="true"
                               data-val-required="Language name is required"
                               placeholder="e.g., Portuguese">
                        <span class="field-validation-valid" data-valmsg-for="LanguageName" data-valmsg-replace="true"></span>
                    </div>
                    <div class="mb-3">
                        <label for="languageCode" class="form-label">Language Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="languageCode" name="LanguageCode"
                               data-val="true"
                               data-val-required="Language code is required"
                               data-val-regex="Please enter a valid language code (e.g., pt-BR)"
                               data-val-regex-pattern="^[a-z]{2}-[A-Z]{2}$"
                               placeholder="e.g., pt-BR">
                        <span class="field-validation-valid" data-valmsg-for="LanguageCode" data-valmsg-replace="true"></span>
                        <small class="text-muted">Format: xx-XX (language-COUNTRY)</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Text Direction <span class="text-danger">*</span></label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="TextDirection" id="dirLTR" value="ltr" checked>
                            <label class="form-check-label" for="dirLTR">Left to Right (LTR)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="TextDirection" id="dirRTL" value="rtl">
                            <label class="form-check-label" for="dirRTL">Right to Left (RTL)</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="languageStatus" class="form-label">Initial Status</label>
                        <select class="form-select" id="languageStatus" name="Status">
                            <option value="draft">Draft (Hidden from users)</option>
                            <option value="active">Active (Visible to users)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add Language</button>
                </div>
            </form>
        </div>
    </div>
</div>
