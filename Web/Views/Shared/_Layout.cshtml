@{
    Layout = null;
    var token = Context.Session.GetString("AuthToken");
    var isLoggedIn = !string.IsNullOrWhiteSpace(token);
    var userRole = Context.Session.GetString("UserRole") ?? "";
    var userName = Context.Session.GetString("UserName") ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userPlan = Context.Session.GetString("UserPlan") ?? "";
    var userPlanExpiresAtStr = Context.Session.GetString("UserPlanExpiresAt") ?? "";
    var planIsExpired = DateTimeOffset.TryParse(userPlanExpiresAtStr, out var planExpiry) && planExpiry <= DateTimeOffset.UtcNow;
    var effectivePlan = (planIsExpired && userPlan != "Free") ? "Free" : userPlan;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - EMS</title>

    <!-- Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.19.0/dist/tabler-icons.min.css">
    <!-- Bootstrap Icons (các view cũ dùng class bi-*) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    @RenderSection("Styles", required: false)
</head>
<body class="antialiased">
    <div class="wrapper">

        @if (isLoggedIn)
        {
            <!-- Sidebar -->
            <aside class="navbar navbar-vertical navbar-expand-lg" data-bs-theme="dark">
                <div class="container-fluid">
                    <!-- Sidebar Toggle (mobile) -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <!-- Brand -->
                    <h1 class="navbar-brand navbar-brand-autodark mb-0">
                        <a asp-controller="Home" asp-action="Index">
                            <i class="ti ti-building me-2"></i>
                            <span>EMS</span>
                        </a>
                    </h1>
                    @if (userRole == "BusinessOwner" && !string.IsNullOrEmpty(effectivePlan))
                    {
                        var planBadgeCss = effectivePlan switch
                        {
                            "Basic" => "bg-info",
                            "Pro"   => "bg-success",
                            _       => "bg-secondary"
                        };
                        <div class="px-3 pb-1">
                            <span class="badge @planBadgeCss text-white badge-pill">
                                <i class="ti ti-credit-card me-1"></i>@effectivePlan
                            </span>
                            @if (planIsExpired && userPlan != "Free")
                            {
                                <span class="badge bg-warning text-dark badge-pill ms-1">Hết hạn</span>
                            }
                        </div>
                    }

                    <!-- User info (mobile) -->
                    <div class="navbar-nav flex-row d-lg-none">
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown">
                                <span class="avatar avatar-sm">@userName.Substring(0, 1).ToUpper()</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                                <div class="dropdown-header">@userName</div>
                                <div class="dropdown-divider"></div>
                                <form method="post" asp-controller="Auth" asp-action="Logout">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="ti ti-logout me-2"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Menu -->
                    <div class="collapse navbar-collapse" id="sidebar-menu">
                        <ul class="navbar-nav pt-lg-3">

                            <!-- Home -->
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Home" ? "active" : "")"
                                   asp-controller="Home" asp-action="Index">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-home"></i>
                                    </span>
                                    <span class="nav-link-title">Home</span>
                                </a>
                            </li>

                            @if (userRole == "Admin")
                            {
                                <!-- Admin section -->
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle @(currentController == "Admin" ? "active" : "")"
                                       href="#" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button"
                                       aria-expanded="@(currentController == "Admin" ? "true" : "false")">
                                        <span class="nav-link-icon d-md-none d-lg-inline-block">
                                            <i class="ti ti-speedometer"></i>
                                        </span>
                                        <span class="nav-link-title">Admin</span>
                                    </a>
                                    <div class="dropdown-menu @(currentController == "Admin" ? "show" : "")">
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "Dashboard" ? "active" : "")"
                                           asp-controller="Admin" asp-action="Dashboard">
                                            <i class="ti ti-layout-dashboard me-2"></i>Dashboard
                                        </a>
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "UserRoleManagement" ? "active" : "")"
                                           asp-controller="Admin" asp-action="UserRoleManagement">
                                            <i class="ti ti-users me-2"></i>User &amp; Role Management
                                        </a>
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "Statistics" ? "active" : "")"
                                           asp-controller="Admin" asp-action="Statistics">
                                            <i class="ti ti-chart-bar me-2"></i>Statistics
                                        </a>
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "Subscription" ? "active" : "")"
                                           asp-controller="Admin" asp-action="Subscription">
                                            <i class="ti ti-credit-card me-2"></i>Subscription
                                        </a>
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "SubscriptionOrders" ? "active" : "")"
                                           asp-controller="Admin" asp-action="SubscriptionOrders">
                                            <i class="ti ti-receipt me-2"></i>Đơn đăng ký
                                        </a>
                                    </div>
                                </li>
                            }

                            <!-- Management section -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(new[]{"Business","Stall","StallLocation","StallGeoFence","StallMedia","Narration"}.Contains(currentController) ? "active" : "")"
                                   href="#" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button"
                                   aria-expanded="@(new[]{"Business","Stall","StallLocation","StallGeoFence","StallMedia","Narration"}.Contains(currentController) ? "true" : "false")">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-settings"></i>
                                    </span>
                                    <span class="nav-link-title">Management</span>
                                </a>
                                <div class="dropdown-menu @(new[]{"Business","Stall","StallLocation","StallGeoFence","StallMedia","Narration"}.Contains(currentController) ? "show" : "")">
                                    @if (userRole == "Admin" || userRole == "BusinessOwner")
                                    {
                                        <a class="dropdown-item @(currentController == "Business" ? "active" : "")"
                                           asp-controller="Business" asp-action="Index">
                                            <i class="ti ti-building-store me-2"></i>Business Management
                                        </a>
                                    }
                                    <a class="dropdown-item @(currentController == "Subscription" && currentAction == "Plans" ? "active" : "")"
                                       asp-controller="Subscription" asp-action="Plans">
                                        <i class="ti ti-layout-grid me-2"></i>Bảng giá
                                    </a>
                                    @if (userRole == "Admin")
                                    {
                                        <a class="dropdown-item @(currentController == "Admin" && currentAction == "Subscription" ? "active" : "")"
                                           asp-controller="Admin" asp-action="Subscription">
                                            <i class="ti ti-credit-card me-2"></i>Subscription
                                        </a>
                                    }
                                    <a class="dropdown-item @(currentController == "Stall" ? "active" : "")"
                                       asp-controller="Stall" asp-action="Index">
                                            <i class="ti ti-building-store me-2"></i>Stall Management
                                    </a>
                                    <a class="dropdown-item @(currentController == "Narration" ? "active" : "")"
                                       asp-controller="Narration" asp-action="StallNarrationContents">
                                        <i class="ti ti-microphone me-2"></i>Narration Contents
                                    </a>
                                    <a class="dropdown-item @(currentController == "StallLocation" ? "active" : "")"
                                       asp-controller="StallLocation" asp-action="Index">
                                        <i class="ti ti-map-pin me-2"></i>Stall Location
                                    </a>
                                    <a class="dropdown-item @(currentController == "StallMedia" ? "active" : "")"
                                       asp-controller="StallMedia" asp-action="Index">
                                        <i class="ti ti-photo me-2"></i>Stall Media
                                    </a>
                                </div>
                            </li>

                        </ul>

                        <!-- Bottom: user profile -->
                        <div class="mt-auto d-none d-lg-block pb-3">
                            <div class="nav-item dropdown">
                                <a href="#" class="nav-link d-flex lh-1 text-reset p-0 px-2 py-2" data-bs-toggle="dropdown">
                                    <span class="avatar avatar-sm me-2">@userName.Substring(0, 1).ToUpper()</span>
                                    <div class="d-none d-xl-block ps-1">
                                        <div class="text-white fw-medium">@userName</div>
                                        <div class="mt-1 small text-white-50">@userRole</div>
                                    </div>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                                    <div class="dropdown-header">@userName</div>
                                    <div class="dropdown-divider"></div>
                                    <form method="post" asp-controller="Auth" asp-action="Logout">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="ti ti-logout me-2"></i>Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        }

        <!-- Page wrapper -->
        <div class="page-wrapper">

            @if (!isLoggedIn)
            {
                <!-- Simple top navbar for guests -->
                <header class="navbar navbar-expand-md d-print-none">
                    <div class="container-xl">
                        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                            <i class="ti ti-building me-2"></i>EMS
                        </a>
                        <div class="navbar-nav ms-auto">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                <i class="ti ti-login me-1"></i>Login
                            </a>
                            <a class="nav-link" asp-controller="Auth" asp-action="Register">
                                <i class="ti ti-user-plus me-1"></i>Register
                            </a>
                        </div>
                    </div>
                </header>
            }

            <!-- Page content -->
            <div class="page-body">
                <div class="container-xl">
                    @RenderBody()
                </div>
            </div>

            <!-- Footer -->
            <footer class="footer footer-transparent d-print-none">
                <div class="container-xl">
                    <div class="row text-center align-items-center">
                        <div class="col-12">
                            <p class="text-muted mb-0">
                                &copy; @DateTime.Now.Year <strong>Enterprise Management System</strong>. All rights reserved.
                            </p>
                        </div>
                    </div>
                </div>
            </footer>

        </div>
    </div>

    <!-- Tabler JS -->
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- jQuery Validation -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sync JWT token to localStorage
        $(document).ready(function () {
            var serverToken = '@Html.Raw(Context.Session.GetString("AuthToken") ?? "")';
            if (serverToken && serverToken.trim() !== '') {
                localStorage.setItem('jwtToken', serverToken);
            } else {
                localStorage.removeItem('jwtToken');
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
