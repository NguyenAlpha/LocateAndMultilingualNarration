@model Web.Models.SubscriptionOrdersViewModel
@{
    ViewData["Title"] = "Đơn đăng ký";
    var startIndex = Model.TotalCount == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endIndex = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<!-- Page Header -->
<div class="page-header" data-aos="fade-up">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item">Quản trị</li>
            <li class="breadcrumb-item active" aria-current="page">Đơn đăng ký</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="ti ti-receipt me-2"></i>Đơn đăng ký Subscription</h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible mb-3" role="alert" data-aos="fade-in">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats cards -->
<div class="row row-deck row-cards mb-4" data-aos="fade-up" data-aos-delay="50">
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Doanh thu (trang này)</div>
                <div class="h1 mb-0 text-success">@Model.TotalRevenue.ToString("N0")đ</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Đơn thành công</div>
                <div class="h1 mb-0 text-primary">@Model.TotalCompleted</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card">
            <div class="card-body">
                <div class="subheader">Đơn thất bại</div>
                <div class="h1 mb-0 text-danger">@Model.TotalFailed</div>
            </div>
        </div>
    </div>
</div>

<!-- Tìm kiếm / Lọc -->
<div class="search-filter-bar" data-aos="fade-up" data-aos-delay="75">
    <form method="get" asp-action="SubscriptionOrders" class="row g-3">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <div class="col-md-3">
            <label for="planFilter" class="form-label visually-hidden">Lọc theo gói</label>
            <select name="plan" class="form-select" id="planFilter">
                <option value="" selected="@(string.IsNullOrEmpty(Model.FilterPlan))">Tất cả gói</option>
                <option value="Basic" selected="@(Model.FilterPlan == "Basic")">Basic</option>
                <option value="Pro" selected="@(Model.FilterPlan == "Pro")">Pro</option>
            </select>
        </div>
        <div class="col-md-3">
            <label for="statusFilter" class="form-label visually-hidden">Lọc theo trạng thái</label>
            <select name="status" class="form-select" id="statusFilter">
                <option value="" selected="@(string.IsNullOrEmpty(Model.FilterStatus))">Tất cả trạng thái</option>
                <option value="Completed" selected="@(Model.FilterStatus == "Completed")">Thành công</option>
                <option value="Failed" selected="@(Model.FilterStatus == "Failed")">Thất bại</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100" type="submit">
                <i class="bi bi-search me-1"></i>Lọc
            </button>
        </div>
        <div class="col-md-2">
            <a class="btn btn-outline-secondary w-100" asp-action="SubscriptionOrders">
                <i class="bi bi-x-circle me-1"></i>Đặt lại
            </a>
        </div>
    </form>
</div>

<!-- Bảng đơn đăng ký -->
<div class="table-container" data-aos="fade-up" data-aos-delay="100">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="text-muted">Hiển thị @startIndex–@endIndex trong @Model.TotalCount đơn</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover table-vcenter" id="ordersTable" aria-label="Danh sách đơn đăng ký">
            <thead>
                <tr>
                    <th scope="col">Business</th>
                    <th scope="col">Gói</th>
                    <th scope="col">Số tiền</th>
                    <th scope="col">Trạng thái</th>
                    <th scope="col">Thẻ</th>
                    <th scope="col">Ngày thanh toán</th>
                    <th scope="col">Hiệu lực đến</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Chưa có đơn đăng ký nào.</td>
                    </tr>
                }
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><span class="fw-medium">@item.BusinessName</span></td>
                        <td>
                            <span class="badge @(item.Plan == "Pro" ? "bg-primary" : "bg-info")">@item.Plan</span>
                        </td>
                        <td class="fw-medium">@item.Amount.ToString("N0")đ</td>
                        <td>
                            @if (item.Status == "Completed")
                            {
                                <span class="badge bg-success">Thành công</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Thất bại</span>
                            }
                        </td>
                        <td class="text-muted">
                            @if (!string.IsNullOrEmpty(item.CardLastFour))
                            {
                                <span>•••• @item.CardLastFour</span>
                            }
                            else
                            {
                                <span>–</span>
                            }
                        </td>
                        <td class="text-muted">@(item.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "–")</td>
                        <td class="text-muted">@item.PlanEndAt.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="d-flex justify-content-end mt-3">
            <nav aria-label="Phân trang đơn đăng ký">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="SubscriptionOrders"
                           asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize"
                           asp-route-plan="@Model.FilterPlan" asp-route-status="@Model.FilterStatus"
                           aria-label="Trang trước"><span aria-hidden="true">&laquo;</span></a>
                    </li>
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="SubscriptionOrders"
                               asp-route-page="@i" asp-route-pageSize="@Model.PageSize"
                               asp-route-plan="@Model.FilterPlan" asp-route-status="@Model.FilterStatus">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="SubscriptionOrders"
                           asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize"
                           asp-route-plan="@Model.FilterPlan" asp-route-status="@Model.FilterStatus"
                           aria-label="Trang sau"><span aria-hidden="true">&raquo;</span></a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
