@model Web.Models.UserRoleManagementViewModel
@{
    ViewData["Title"] = "Quản lý User & Role";
    var totalPages = Model.PageSize > 0 ? (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize) : 1;
    var startItem = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    var endItem = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<!-- Page Header -->
<div class="page-header" data-aos="fade-up">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item">Quản trị</li>
            <li class="breadcrumb-item active" aria-current="page">Quản lý User &amp; Role</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1><i class="bi bi-people me-2"></i>Quản lý User &amp; Role</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-person-plus me-1"></i>Thêm User mới
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Tabs -->
<ul class="nav nav-tabs mb-4" id="userManagementTabs" role="tablist" data-aos="fade-up" data-aos-delay="50">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
            <i class="bi bi-people me-1"></i>Người dùng
            <span class="badge bg-secondary ms-1">@Model.TotalCount</span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="roles-tab" data-bs-toggle="tab" data-bs-target="#roles" type="button" role="tab">
            <i class="bi bi-shield-lock me-1"></i>Vai trò
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="permissions-tab" data-bs-toggle="tab" data-bs-target="#permissions" type="button" role="tab">
            <i class="bi bi-key me-1"></i>Quyền hạn
        </button>
    </li>
</ul>

<div class="tab-content" id="userManagementTabContent">

    <!-- Users Tab -->
    <div class="tab-pane fade show active" id="users" role="tabpanel">

        <!-- Search/Filter Form -->
        <div class="search-filter-bar mb-3">
            <form method="get" asp-action="UserRoleManagement" asp-controller="Admin" class="row g-3">
                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <div class="col-md-4">
                    <label for="userSearch" class="form-label visually-hidden">Tìm user</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control table-search" id="userSearch" name="search"
                               value="@Model.Search" placeholder="Tìm email hoặc username...">
                    </div>
                </div>
                <div class="col-md-2">
                    <label for="roleFilterSelect" class="form-label visually-hidden">Lọc theo Role</label>
                    <select class="form-select" id="roleFilterSelect" name="roleFilter">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.RoleFilter))">Tất cả Role</option>
                        <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
                        <option value="BusinessOwner" selected="@(Model.RoleFilter == "BusinessOwner")">BusinessOwner</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="activeFilterSelect" class="form-label visually-hidden">Lọc theo trạng thái</label>
                    <select class="form-select" id="activeFilterSelect" name="isActiveFilter">
                        <option value="" selected="@(Model.IsActiveFilter == null)">Tất cả trạng thái</option>
                        <option value="true" selected="@(Model.IsActiveFilter == true)">Hoạt động</option>
                        <option value="false" selected="@(Model.IsActiveFilter == false)">Tạm dừng</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-search me-1"></i>Tìm kiếm
                    </button>
                </div>
                <div class="col-md-2">
                    <a class="btn btn-outline-secondary w-100"
                       asp-action="UserRoleManagement" asp-controller="Admin">
                        <i class="bi bi-x-circle me-1"></i>Đặt lại
                    </a>
                </div>
            </form>
        </div>

        <!-- Users Table -->
        <div class="table-container" data-aos="fade-up" data-aos-delay="100">
            <div class="table-responsive">
                <table class="table table-hover" id="usersTable">
                    <thead>
                        <tr>
                            <th scope="col">Người dùng</th>
                            <th scope="col">Email</th>
                            <th scope="col">Vai trò</th>
                            <th scope="col">Trạng thái</th>
                            <th scope="col">Đăng nhập cuối</th>
                            <th scope="col">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            var initial = u.UserName?.Length > 0 ? u.UserName.Substring(0, 1).ToUpper() : "?";
                            var primaryRole = u.Roles.FirstOrDefault() ?? "";
                            var roleBadge = primaryRole == "Admin" ? "bg-danger" : "bg-primary";
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2"
                                             style="width:32px;height:32px;font-size:14px;flex-shrink:0;">
                                            @initial
                                        </div>
                                        <div>@u.UserName</div>
                                    </div>
                                </td>
                                <td>@u.Email</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(primaryRole))
                                    {
                                        <span class="badge @roleBadge">@primaryRole</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">–</span>
                                    }
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Tạm dừng</span>
                                    }
                                </td>
                                <td>
                                    @(u.LastLoginAt.HasValue ? u.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm") : "–")
                                </td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <!-- Toggle Active -->
                                        <form method="post" asp-action="ToggleUserActive" asp-controller="Admin"
                                              asp-route-id="@u.Id"
                                              asp-route-page="@Model.Page" asp-route-pageSize="@Model.PageSize"
                                              asp-route-search="@Model.Search" asp-route-roleFilter="@Model.RoleFilter"
                                              asp-route-isActiveFilter="@Model.IsActiveFilter"
                                              style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                    title="@(u.IsActive ? "Vô hiệu hóa" : "Kích hoạt")"
                                                    onclick="return confirm('@(u.IsActive ? "Vô hiệu hóa" : "Kích hoạt") user @u.UserName?')">
                                                <i class="bi @(u.IsActive ? "bi-person-slash" : "bi-person-check")"></i>
                                            </button>
                                        </form>

                                        <!-- Change Role -->
                                        <form method="post" asp-action="UpdateUserRole" asp-controller="Admin"
                                              asp-route-id="@u.Id"
                                              asp-route-page="@Model.Page" asp-route-pageSize="@Model.PageSize"
                                              asp-route-search="@Model.Search" asp-route-roleFilter="@Model.RoleFilter"
                                              asp-route-isActiveFilter="@Model.IsActiveFilter"
                                              class="d-flex gap-1">
                                            @Html.AntiForgeryToken()
                                            <select name="roleName" class="form-select form-select-sm" style="width:auto;">
                                                <option value="Admin" selected="@(primaryRole == "Admin")">Admin</option>
                                                <option value="BusinessOwner" selected="@(primaryRole == "BusinessOwner")">BusinessOwner</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-primary" title="Đổi role">
                                                <i class="bi bi-arrow-repeat"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-3 d-block mb-2"></i>Không có user nào.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalCount > 0)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Hiển thị @startItem–@endItem trong @Model.TotalCount users
                    </div>
                    @if (totalPages > 1)
                    {
                        <nav>
                            <ul class="pagination mb-0">
                                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="UserRoleManagement" asp-controller="Admin"
                                       asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize"
                                       asp-route-search="@Model.Search" asp-route-roleFilter="@Model.RoleFilter"
                                       asp-route-isActiveFilter="@Model.IsActiveFilter">&laquo;</a>
                                </li>
                                @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(totalPages, Model.Page + 2); p++)
                                {
                                    <li class="page-item @(p == Model.Page ? "active" : "")">
                                        <a class="page-link" asp-action="UserRoleManagement" asp-controller="Admin"
                                           asp-route-page="@p" asp-route-pageSize="@Model.PageSize"
                                           asp-route-search="@Model.Search" asp-route-roleFilter="@Model.RoleFilter"
                                           asp-route-isActiveFilter="@Model.IsActiveFilter">@p</a>
                                    </li>
                                }
                                <li class="page-item @(Model.Page >= totalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="UserRoleManagement" asp-controller="Admin"
                                       asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize"
                                       asp-route-search="@Model.Search" asp-route-roleFilter="@Model.RoleFilter"
                                       asp-route-isActiveFilter="@Model.IsActiveFilter">&raquo;</a>
                                </li>
                            </ul>
                        </nav>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Roles Tab -->
    <div class="tab-pane fade" id="roles" role="tabpanel">
        <div class="row">
            @foreach (var r in Model.Roles)
            {
                var headerClass = r.Name == "Admin" ? "bg-danger" : "bg-primary";
                var icon = r.Name == "Admin" ? "bi-shield-fill-check" : "bi-person-badge";
                var description = r.Name == "Admin"
                    ? "Toàn quyền truy cập hệ thống, quản lý tất cả users và dữ liệu."
                    : "Quản lý business, stalls, narration và subscription của mình.";
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header @headerClass text-white">
                            <h5 class="mb-0"><i class="bi @icon me-2"></i>@r.Name</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@description</p>
                            <p class="text-muted small mb-2">Số user: <strong>@r.UserCount</strong></p>
                        </div>
                        <div class="card-footer">
                            <a asp-action="UserRoleManagement" asp-controller="Admin"
                               asp-route-roleFilter="@r.Name"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-people me-1"></i>Xem Users
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Permissions Tab (static) -->
    <div class="tab-pane fade" id="permissions" role="tabpanel">
        <div class="table-container">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th scope="col">Quyền hạn</th>
                            <th scope="col" class="text-center">Admin</th>
                            <th scope="col" class="text-center">BusinessOwner</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="table-light"><td colspan="3"><strong>Quản lý Doanh nghiệp</strong></td></tr>
                        <tr>
                            <td>Xem tất cả Business</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-dash-circle text-muted" title="Chỉ business của mình"></i></td>
                        </tr>
                        <tr>
                            <td>Tạo / Sửa / Kích hoạt Business</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-dash-circle text-muted" title="Chỉ business của mình"></i></td>
                        </tr>
                        <tr class="table-light"><td colspan="3"><strong>Quản lý Gian hàng</strong></td></tr>
                        <tr>
                            <td>Xem / Tạo / Sửa Stall</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-dash-circle text-muted" title="Chỉ stall thuộc business của mình"></i></td>
                        </tr>
                        <tr class="table-light"><td colspan="3"><strong>Subscription</strong></td></tr>
                        <tr>
                            <td>Nâng cấp / Xem tất cả đơn đăng ký</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-x-circle-fill text-danger"></i></td>
                        </tr>
                        <tr>
                            <td>Đăng ký gói (Basic/Pro)</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                        </tr>
                        <tr class="table-light"><td colspan="3"><strong>Quản lý Người dùng</strong></td></tr>
                        <tr>
                            <td>Xem / Tạo / Đổi role / Toggle active</td>
                            <td class="text-center"><i class="bi bi-check-circle-fill text-success"></i></td>
                            <td class="text-center"><i class="bi bi-x-circle-fill text-danger"></i></td>
                        </tr>
                    </tbody>
                </table>
                <p class="text-muted small mt-2">
                    <i class="bi bi-dash-circle me-1"></i> = chỉ truy cập dữ liệu của mình
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addUserModalLabel"><i class="bi bi-person-plus me-2"></i>Thêm User Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="AdminCreateUser" asp-controller="Admin">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="userName" class="form-label">Username <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="userName" name="UserName"
                                   placeholder="Nhập username" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" name="Email"
                                   placeholder="Nhập email" required>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="password" name="Password"
                                   placeholder="Tối thiểu 6 ký tự" required minlength="6">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="phoneNumber" class="form-label">Số điện thoại</label>
                            <input type="tel" class="form-control" id="phoneNumber" name="PhoneNumber"
                                   placeholder="+84 xxx xxx xxx">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="roleName" class="form-label">Role <span class="text-danger">*</span></label>
                        <select class="form-select" id="roleName" name="RoleName" required>
                            <option value="">-- Chọn role --</option>
                            <option value="Admin">Admin</option>
                            <option value="BusinessOwner">BusinessOwner</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-person-plus me-1"></i>Tạo User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
