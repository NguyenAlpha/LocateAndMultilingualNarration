@{
    ViewData["Title"] = "Tạo QR tự động";
}
// Mã này sử dụng JavaScript để quản lý trạng thái tạo QR tự động, hiển thị mã QR mới mỗi khi khách quét mã hiện tại.
@Html.AntiForgeryToken()

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">Admin</div>
                <h2 class="page-title">Tạo QR tự động</h2>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">

                <!-- Setup card (hiển thị khi chưa bắt đầu) -->
                <div id="setupCard" class="card">
                    <div class="card-header">
                        <h3 class="card-title"><i class="ti ti-qrcode me-2"></i>Cài đặt</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            Hệ thống sẽ tự động tạo mã QR mới mỗi khi khách quét mã hiện tại.
                        </p>
                        <div class="mb-3">
                            <label class="form-label required">Số ngày hiệu lực mỗi mã</label>
                            <input type="number" id="validDaysInput" class="form-control"
                                   min="1" value="30" placeholder="VD: 30" />
                            <small class="text-muted">Thiết bị quét sẽ dùng được app trong số ngày này.</small>
                        </div>
                    </div>
                    <div class="card-footer">
                        <button id="btnStart" class="btn btn-primary w-100" onclick="startAutoQr()">
                            <i class="ti ti-player-play me-1"></i>Bắt đầu
                        </button>
                    </div>
                </div>

                <!-- QR display card (ẩn khi chưa bắt đầu) -->
                <div id="qrCard" class="card d-none">
                    <div class="card-header">
                        <h3 class="card-title"><i class="ti ti-qrcode me-2"></i>Mã QR hiện tại</h3>
                        <div class="card-options">
                            <span id="validDaysBadge" class="badge bg-blue-lt me-2"></span>
                            <button class="btn btn-sm btn-ghost-danger" onclick="stopAutoQr()">
                                <i class="ti ti-player-stop me-1"></i>Dừng
                            </button>
                        </div>
                    </div>
                    <div class="card-body text-center py-4">

                        <!-- Status banner -->
                        <div id="statusBanner" class="alert alert-info mb-3 d-none" role="alert">
                            <div class="d-flex align-items-center justify-content-center gap-2">
                                <div class="spinner-border spinner-border-sm" role="status"></div>
                                <span>Đang chờ khách quét...</span>
                            </div>
                        </div>

                        <!-- Scanned flash -->
                        <div id="scannedBanner" class="alert alert-success mb-3 d-none" role="alert">
                            <i class="ti ti-check me-1"></i><strong>Đã quét!</strong> Đang tạo mã mới...
                        </div>

                        <!-- QR image -->
                        <div id="qrImageWrap" class="position-relative d-inline-block">
                            <img id="qrImage" src="" alt="QR Code"
                                 class="border rounded shadow-sm"
                                 style="width: 260px; height: 260px;" />
                            <!-- Overlay khi đang refresh -->
                            <div id="qrOverlay" class="d-none position-absolute top-0 start-0 w-100 h-100
                                                        d-flex align-items-center justify-content-center
                                                        bg-white bg-opacity-75 rounded">
                                <div class="spinner-border text-primary" role="status"></div>
                            </div>
                        </div>

                        <p class="mt-3 mb-0 text-muted small">
                            Code: <code id="qrCodeText"></code>
                        </p>
                        <p class="text-muted small mb-0" id="scannedCount"></p>
                        <div class="mt-3">
                            <a id="btnDownload" href="#" download="QRCode.png"
                               class="btn btn-outline-secondary btn-sm" onclick="downloadQr(event)">
                                <i class="ti ti-download me-1"></i>Download
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // --- Trạng thái toàn cục ---
    // currentId: ID của QR đang hiển thị, dùng để poll kiểm tra đã bị quét chưa
    // validDays: số ngày hiệu lực người dùng nhập, giữ lại để tạo mã tiếp theo
    // pollTimer: ID của setInterval, cần lưu để clearInterval khi dừng
    // scannedTotal: đếm tổng số lần khách quét trong phiên hiện tại
    // POLL_MS: tần suất gọi API kiểm tra (2 giây/lần)
    let currentId    = null;
    let validDays    = 30;
    let pollTimer    = null;
    let scannedTotal = 0;
    const POLL_MS    = 2000;

    // Bước 1: Admin nhấn "Bắt đầu" → validate input → gọi API tạo QR đầu tiên → chuyển sang chế độ hiển thị
    async function startAutoQr() {
        validDays = parseInt(document.getElementById('validDaysInput').value, 10);
        if (!validDays || validDays < 1) {
            alert('Vui lòng nhập số ngày hợp lệ.');
            return;
        }

        // Disable nút để tránh nhấn nhiều lần trong lúc đang gọi API
        const btn = document.getElementById('btnStart');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang tạo...';

        try {
            // Gửi antiforgery token trong header vì đây là AJAX POST, không phải form submit thông thường
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const res = await fetch('/Admin/StartAutoQr', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ validDays })
            });
            const data = await res.json();
            if (!res.ok) { alert(data.error || 'Lỗi tạo QR.'); return; }

            showQrCard(data);   // hiển thị ảnh QR vừa tạo
            startPolling();     // bắt đầu vòng lặp kiểm tra đã quét chưa
        } finally {
            // Luôn restore nút dù thành công hay lỗi
            btn.disabled = false;
            btn.innerHTML = '<i class="ti ti-player-play me-1"></i>Bắt đầu';
        }
    }

    // Render thông tin QR mới vào card: lưu ID, hiện ảnh, ẩn/hiện các banner
    // Hàm này được gọi cả lần đầu lẫn mỗi khi swap sang mã mới
    function showQrCard(data) {
        currentId = data.id;

        // Chỉ hiển thị 4 ký tự cuối của code để tránh lộ toàn bộ mã trên màn hình kiosk
        document.getElementById('qrCodeText').textContent = '****' + data.code.slice(-4);
        document.getElementById('validDaysBadge').textContent = validDays + ' ngày';

        // Chuyển giao diện từ setup card sang QR card
        document.getElementById('setupCard').classList.add('d-none');
        document.getElementById('qrCard').classList.remove('d-none');
        document.getElementById('statusBanner').classList.remove('d-none');
        document.getElementById('scannedBanner').classList.add('d-none');
        updateScannedCount();

        // Gán src sau khi đăng ký onload/onerror để tránh race condition:
        // nếu gán src trước, sự kiện load có thể fire trước khi handler được gắn
        const img = document.getElementById('qrImage');
        img.onload  = () => document.getElementById('qrOverlay').classList.add('d-none');
        img.onerror = () => document.getElementById('qrOverlay').classList.add('d-none');
        img.src = data.imageUrl;
    }

    // Khởi động vòng lặp poll — clearInterval trước để đảm bảo không chạy 2 timer song song
    function startPolling() {
        clearInterval(pollTimer);
        pollTimer = setInterval(poll, POLL_MS);
    }

    // Mỗi 2 giây gọi PollAutoQr để hỏi server: QR hiện tại đã bị quét chưa?
    // Nếu chưa quét (data.used = false) → bỏ qua, chờ tick tiếp theo
    // Nếu đã quét → hiện thông báo, dừng timer, đợi 1.2s rồi swap sang mã mới
    async function poll() {
        if (!currentId) return;
        try {
            // PollAutoQr trả về QR cũ (với used=true) hoặc QR mới (nếu server đã tạo sẵn)
            const res  = await fetch(`/Admin/PollAutoQr?id=${currentId}&validDays=${validDays}`);
            const data = await res.json();
            if (!data.used) return;

            scannedTotal++;
            clearInterval(pollTimer); // dừng timer ngay, tránh poll tiếp trong lúc đang swap

            // Hiện flash "Đã quét" + spinner overlay lên ảnh QR cũ
            document.getElementById('statusBanner').classList.add('d-none');
            document.getElementById('scannedBanner').classList.remove('d-none');
            document.getElementById('qrOverlay').classList.remove('d-none');

            // Cho Admin thấy thông báo 1.2s trước khi ảnh QR mới xuất hiện
            setTimeout(() => {
                showQrCard(data);
                startPolling();
            }, 1200);
        } catch (e) {
            // Lỗi mạng tạm thời (timeout, mất kết nối) → im lặng, tick tiếp theo sẽ thử lại
        }
    }

    // Admin nhấn "Dừng" → xoá timer, reset state, quay về setup card
    function stopAutoQr() {
        clearInterval(pollTimer);
        pollTimer = null;
        currentId = null;
        document.getElementById('qrCard').classList.add('d-none');
        document.getElementById('setupCard').classList.remove('d-none');
        document.getElementById('qrOverlay').classList.add('d-none');
    }

    function updateScannedCount() {
        const el = document.getElementById('scannedCount');
        el.textContent = scannedTotal > 0 ? `Đã phát: ${scannedTotal} lượt` : '';
    }

    // Download ảnh QR: tạo thẻ <a> tạm, trigger click để trình duyệt tải file
    // Không thể dùng href trực tiếp vì src là data URL từ API, không phải file tĩnh
    function downloadQr(e) {
        e.preventDefault();
        const img = document.getElementById('qrImage');
        if (!img.src) return;
        const a = document.createElement('a');
        a.href = img.src;
        a.download = 'QRCode.png';
        a.click();
    }
</script>
}
