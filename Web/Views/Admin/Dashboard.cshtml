@model Web.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<!-- Page header -->
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">Overview</div>
                <h2 class="page-title">Admin Dashboard</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <div class="d-flex">
                    <span class="text-muted me-2 d-flex align-items-center">
                        <i class="ti ti-refresh me-1"></i>
                        Last updated: @DateTime.Now.ToString("HH:mm, dd/MM/yyyy")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">

        <!-- ==================== STATS CARDS (thật) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Total Businesses</div>
                        </div>
                        <div class="h1 mb-3">@Model.TotalBusinesses</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Business" asp-action="Index" class="text-primary text-decoration-none">
                                    View all <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-primary" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Total Stalls</div>
                        <div class="h1 mb-3">@Model.TotalStalls</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Stall" asp-action="Index" class="text-green text-decoration-none">
                                    View all <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-green" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Active Languages</div>
                        <div class="h1 mb-3">@Model.ActiveLanguages</div>
                        <div class="d-flex mb-2">
                            <div class="text-muted">
                                <i class="ti ti-language me-1"></i>Supported narration languages
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-yellow" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Narration Contents</div>
                        <div class="h1 mb-3">@Model.TotalNarrationContents</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Narration" asp-action="StallNarrationContents" class="text-orange text-decoration-none">
                                    View all <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-orange" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== STATS HARDCODE (chưa có data thật) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="subheader">Total Visitors</div>
                            <span class="badge bg-orange-lt ms-auto">Hardcoded</span>
                        </div>
                        <div class="h1 mb-1">3,847</div>
                        <div class="text-muted small">
                            <i class="ti ti-arrow-up text-success me-1"></i>+156 this month
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="subheader">Audio Files Generated</div>
                            <span class="badge bg-orange-lt ms-auto">Hardcoded</span>
                        </div>
                        <div class="h1 mb-1">1,204</div>
                        <div class="text-muted small">
                            <i class="ti ti-arrow-up text-success me-1"></i>+43 this week
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="subheader">Registered Users</div>
                            <span class="badge bg-orange-lt ms-auto">Hardcoded</span>
                        </div>
                        <div class="h1 mb-1">248</div>
                        <div class="text-muted small">
                            <i class="ti ti-arrow-up text-success me-1"></i>+8 new this week
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <div class="subheader">GeoFence Triggers</div>
                            <span class="badge bg-orange-lt ms-auto">Hardcoded</span>
                        </div>
                        <div class="h1 mb-1">9,512</div>
                        <div class="text-muted small">
                            <i class="ti ti-arrow-up text-success me-1"></i>+321 today
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== RECENT BUSINESSES (thật) + LANGUAGES (thật) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <!-- Recent Businesses -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-building-store me-2 text-primary"></i>Recent Businesses
                        </h3>
                        <div class="card-options">
                            <a asp-controller="Business" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                View all
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Tax Code</th>
                                    <th>Contact</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentBusinesses.Any())
                                {
                                    @foreach (var b in Model.RecentBusinesses)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium">@b.Name</div>
                                            </td>
                                            <td class="text-muted">@(b.TaxCode ?? "—")</td>
                                            <td class="text-muted">@(b.ContactEmail ?? b.ContactPhone ?? "—")</td>
                                            <td>
                                                @if (b.IsActive)
                                                {
                                                    <span class="badge bg-success-lt text-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-lt text-danger">Inactive</span>
                                                }
                                            </td>
                                            <td class="text-muted">@b.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="ti ti-database-off me-2"></i>No businesses found
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Active Languages -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-language me-2 text-yellow"></i>Active Languages
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @if (Model.Languages.Any())
                            {
                                @foreach (var lang in Model.Languages)
                                {
                                    <li class="list-group-item d-flex align-items-center py-3">
                                        @if (!string.IsNullOrEmpty(lang.FlagCode))
                                        {
                                            <span class="me-3 fs-3">@lang.FlagCode</span>
                                        }
                                        else
                                        {
                                            <span class="avatar avatar-sm me-3 bg-primary-lt text-primary">
                                                @lang.Code.Substring(0, 2).ToUpper()
                                            </span>
                                        }
                                        <div>
                                            <div class="fw-medium">@(lang.DisplayName ?? lang.Name)</div>
                                            <div class="text-muted small">@lang.Code</div>
                                        </div>
                                        <span class="badge bg-success-lt text-success ms-auto">Active</span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-center text-muted py-4">
                                    <i class="ti ti-language-off me-2"></i>No languages configured
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== RECENT STALLS (thật) + SYSTEM STATUS (hardcode) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <!-- Recent Stalls -->
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-store me-2 text-green"></i>Recent Stalls
                        </h3>
                        <div class="card-options">
                            <a asp-controller="Stall" asp-action="Index" class="btn btn-sm btn-outline-success">
                                View all
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Slug</th>
                                    <th>Contact</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentStalls.Any())
                                {
                                    @foreach (var s in Model.RecentStalls)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium">@s.Name</div>
                                                <div class="text-muted small">@s.Description</div>
                                            </td>
                                            <td class="text-muted"><code>@s.Slug</code></td>
                                            <td class="text-muted">@(s.ContactEmail ?? s.ContactPhone ?? "—")</td>
                                            <td>
                                                @if (s.IsActive)
                                                {
                                                    <span class="badge bg-success-lt text-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-lt text-danger">Inactive</span>
                                                }
                                            </td>
                                            <td class="text-muted">@s.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="ti ti-database-off me-2"></i>No stalls found
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- System Status (hardcode) -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-server me-2"></i>System Status
                        </h3>
                        <div class="card-options">
                            <span class="badge bg-orange-lt">Hardcoded</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">API Server</span>
                                <span class="badge bg-success-lt text-success">Online</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Database</span>
                                <span class="badge bg-success-lt text-success">Connected</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Azure Speech</span>
                                <span class="badge bg-success-lt text-success">Running</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Azure Blob</span>
                                <span class="badge bg-success-lt text-success">Running</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Azure Translator</span>
                                <span class="badge bg-success-lt text-success">Running</span>
                            </div>
                        </div>
                        <hr>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">CPU Usage</span>
                                <span class="small">45%</span>
                            </div>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-success" style="width: 45%" role="progressbar"></div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Memory</span>
                                <span class="small">62%</span>
                            </div>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-warning" style="width: 62%" role="progressbar"></div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted small">Storage</span>
                                <span class="small">78%</span>
                            </div>
                            <div class="progress progress-sm">
                                <div class="progress-bar bg-danger" style="width: 78%" role="progressbar"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== CHARTS (hardcode) ==================== -->
        <div class="row row-deck row-cards">

            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-chart-bar me-2"></i>Stall Registrations by Month
                        </h3>
                        <div class="card-options">
                            <span class="badge bg-orange-lt">Hardcoded</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="chart-stalls-monthly" style="height: 200px;"></div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-chart-donut me-2"></i>Visitors by Language
                        </h3>
                        <div class="card-options">
                            <span class="badge bg-orange-lt">Hardcoded</span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="chart-visitors-language" style="height: 200px;"></div>
                        <div class="mt-3">
                            @foreach (var lang in Model.Languages.Take(4))
                            {
                                <div class="d-flex align-items-center mb-2">
                                    <span class="me-2">@(lang.DisplayName ?? lang.Name)</span>
                                    <div class="progress flex-grow-1 me-2 progress-sm">
                                        <div class="progress-bar bg-primary" style="width: @(new Random().Next(20, 80))%"></div>
                                    </div>
                                    <span class="text-muted small">~@(new Random().Next(10, 40))%</span>
                                </div>
                            }
                            @if (!Model.Languages.Any())
                            {
                                <div class="text-center text-muted">No language data</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts {
<script>
    // Chart: Stalls by month (hardcode)
    document.addEventListener("DOMContentLoaded", function () {
        if (typeof ApexCharts === 'undefined') return;

        new ApexCharts(document.getElementById('chart-stalls-monthly'), {
            chart: { type: 'bar', height: 200, toolbar: { show: false }, sparkline: { enabled: false } },
            series: [{ name: 'Stalls', data: [12, 18, 25, 30, 22, 35, 40, 28, 45, 38, 50, 42] }],
            xaxis: { categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'] },
            colors: ['#206bc4'],
            plotOptions: { bar: { borderRadius: 4 } },
            dataLabels: { enabled: false },
            grid: { strokeDashArray: 4 },
        }).render();

        new ApexCharts(document.getElementById('chart-visitors-language'), {
            chart: { type: 'donut', height: 200, toolbar: { show: false } },
            series: [35, 28, 22, 15],
            labels: ['Vietnamese', 'English', 'Japanese', 'Korean'],
            colors: ['#206bc4', '#2fb344', '#f76707', '#ae3ec9'],
            legend: { show: false },
            dataLabels: { enabled: false },
        }).render();
    });
</script>
}
