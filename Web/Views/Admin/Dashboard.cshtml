@model Web.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<!-- Page header -->
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">Tổng quan</div>
                <h2 class="page-title">Bảng điều khiển</h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <div class="d-flex">
                    <span class="text-muted me-2 d-flex align-items-center">
                        <i class="ti ti-refresh me-1"></i>
                        Cập nhật lúc: @DateTime.Now.ToString("HH:mm, dd/MM/yyyy")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">

        <!-- ==================== STATS CARDS (thật) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="0">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Tổng Doanh nghiệp</div>
                        </div>
                        <div class="h1 mb-3">@Model.TotalBusinesses</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Business" asp-action="Index" class="text-primary text-decoration-none">
                                    Xem tất cả <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-primary" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Tổng Gian hàng</div>
                        <div class="h1 mb-3">@Model.TotalStalls</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Stall" asp-action="Index" class="text-green text-decoration-none">
                                    Xem tất cả <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-green" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Ngôn ngữ đang hoạt động</div>
                        <div class="h1 mb-3">@Model.ActiveLanguages</div>
                        <div class="d-flex mb-2">
                            <div class="text-muted">
                                <i class="ti ti-language me-1"></i>Ngôn ngữ thuyết minh được hỗ trợ
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-yellow" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                <div class="card">
                    <div class="card-body">
                        <div class="subheader">Nội dung Thuyết minh</div>
                        <div class="h1 mb-3">@Model.TotalNarrationContents</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Narration" asp-action="StallNarrationContents" class="text-orange text-decoration-none">
                                    Xem tất cả <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-orange" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== STATS CARDS (thật) – hàng 2 ==================== -->
        <div class="row row-deck row-cards mb-4">

            <!-- Tổng người dùng -->
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="0">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Người dùng hệ thống</div>
                        </div>
                        <div class="h1 mb-3">@Model.TotalUsers</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Admin" asp-action="UserRoleManagement" class="text-purple text-decoration-none">
                                    Quản lý <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-purple" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Mã QR -->
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Mã QR</div>
                        </div>
                        <div class="h1 mb-1">@Model.TotalQrCodes</div>
                        <div class="text-muted small mb-2">
                            <span class="text-success me-2"><i class="ti ti-check me-1"></i>@Model.UsedQrCodes đã dùng</span>
                            <span class="text-secondary">@(Model.TotalQrCodes - Model.UsedQrCodes) chưa dùng</span>
                        </div>
                        <div class="progress progress-sm">
                            @{
                                var qrPct = Model.TotalQrCodes > 0 ? (int)(Model.UsedQrCodes * 100.0 / Model.TotalQrCodes) : 0;
                            }
                            <div class="progress-bar bg-cyan" style="width: @qrPct%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Đơn thanh toán thành công -->
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Đơn thành công</div>
                        </div>
                        <div class="h1 mb-3">@Model.CompletedOrders</div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Admin" asp-action="SubscriptionOrders" class="text-teal text-decoration-none">
                                    Xem đơn <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-teal" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Doanh thu -->
            <div class="col-sm-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Doanh thu</div>
                        </div>
                        <div class="h1 mb-3">@Model.TotalRevenue.ToString("N0") <small class="fs-4 text-muted">₫</small></div>
                        <div class="d-flex mb-2">
                            <div>
                                <a asp-controller="Admin" asp-action="SubscriptionOrders" class="text-lime text-decoration-none">
                                    Chi tiết <i class="ti ti-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-lime" style="width: 100%" role="progressbar"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== RECENT BUSINESSES (thật) + LANGUAGES (thật) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <!-- Recent Businesses -->
            <div class="col-lg-8" data-aos="fade-up" data-aos-delay="0">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-building-store me-2 text-primary"></i>Doanh nghiệp mới nhất
                        </h3>
                        <div class="card-options">
                            <a asp-controller="Business" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                Xem tất cả
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Tên</th>
                                    <th>Mã số thuế</th>
                                    <th>Liên hệ</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentBusinesses.Any())
                                {
                                    @foreach (var b in Model.RecentBusinesses)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium">@b.Name</div>
                                            </td>
                                            <td class="text-muted">@(b.TaxCode ?? "—")</td>
                                            <td class="text-muted">@(b.ContactEmail ?? b.ContactPhone ?? "—")</td>
                                            <td>
                                                @if (b.IsActive)
                                                {
                                                    <span class="badge bg-success-lt text-success">Hoạt động</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-lt text-danger">Tạm dừng</span>
                                                }
                                            </td>
                                            <td class="text-muted">@b.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="ti ti-database-off me-2"></i>Chưa có doanh nghiệp nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Active Languages -->
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-language me-2 text-yellow"></i>Ngôn ngữ đang dùng
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @if (Model.Languages.Any())
                            {
                                @foreach (var lang in Model.Languages)
                                {
                                    <li class="list-group-item d-flex align-items-center py-3">
                                        @if (!string.IsNullOrEmpty(lang.FlagCode))
                                        {
                                            <span class="me-3 fs-3">@lang.FlagCode</span>
                                        }
                                        else
                                        {
                                            <span class="avatar avatar-sm me-3 bg-primary-lt text-primary">
                                                @lang.Code.Substring(0, 2).ToUpper()
                                            </span>
                                        }
                                        <div>
                                            <div class="fw-medium">@(lang.DisplayName ?? lang.Name)</div>
                                            <div class="text-muted small">@lang.Code</div>
                                        </div>
                                        <span class="badge bg-success-lt text-success ms-auto">Hoạt động</span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-center text-muted py-4">
                                    <i class="ti ti-language-off me-2"></i>Chưa cấu hình ngôn ngữ nào
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== RECENT STALLS (thật) + SYSTEM STATUS (hardcode) ==================== -->
        <div class="row row-deck row-cards mb-4">

            <!-- Recent Stalls -->
            <div class="col-lg-8" data-aos="fade-up" data-aos-delay="0">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-store me-2 text-green"></i>Gian hàng mới nhất
                        </h3>
                        <div class="card-options">
                            <a asp-controller="Stall" asp-action="Index" class="btn btn-sm btn-outline-success">
                                Xem tất cả
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Tên</th>
                                    <th>Slug</th>
                                    <th>Liên hệ</th>
                                    <th>Trạng thái</th>
                                    <th>Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentStalls.Any())
                                {
                                    @foreach (var s in Model.RecentStalls)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-medium">@s.Name</div>
                                                <div class="text-muted small">@s.Description</div>
                                            </td>
                                            <td class="text-muted"><code>@s.Slug</code></td>
                                            <td class="text-muted">@(s.ContactEmail ?? s.ContactPhone ?? "—")</td>
                                            <td>
                                                @if (s.IsActive)
                                                {
                                                    <span class="badge bg-success-lt text-success">Hoạt động</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-lt text-danger">Tạm dừng</span>
                                                }
                                            </td>
                                            <td class="text-muted">@s.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="ti ti-database-off me-2"></i>Chưa có gian hàng nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- System Status -->
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-server me-2"></i>Trạng thái Hệ thống
                        </h3>
                        <div class="card-options">
                            <span class="badge bg-success-lt text-success">
                                <i class="ti ti-circle-filled me-1" style="font-size:8px"></i>Trực tuyến
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="ti ti-api me-2"></i>API Server</span>
                                <span class="badge bg-success-lt text-success">Trực tuyến</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="ti ti-database me-2"></i>Cơ sở dữ liệu</span>
                                <span class="badge bg-success-lt text-success">Đã kết nối</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="ti ti-microphone me-2"></i>Azure Speech</span>
                                <span class="badge bg-success-lt text-success">Đang chạy</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="ti ti-cloud me-2"></i>Azure Blob</span>
                                <span class="badge bg-success-lt text-success">Đang chạy</span>
                            </div>
                        </div>
                        <div class="mb-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted"><i class="ti ti-language me-2"></i>Azure Translator</span>
                                <span class="badge bg-success-lt text-success">Đang chạy</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- ==================== RECENT ORDERS (thật) ==================== -->
        <div class="row row-deck row-cards">

            <div class="col-12" data-aos="fade-up" data-aos-delay="0">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="ti ti-receipt me-2 text-teal"></i>Đơn đăng ký gần đây
                        </h3>
                        <div class="card-options">
                            <a asp-controller="Admin" asp-action="SubscriptionOrders" class="btn btn-sm btn-outline-teal">
                                Xem tất cả
                            </a>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table">
                            <thead>
                                <tr>
                                    <th>Doanh nghiệp</th>
                                    <th>Gói</th>
                                    <th>Số tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Thẻ</th>
                                    <th>Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentOrders.Any())
                                {
                                    @foreach (var o in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td class="fw-medium">@o.BusinessName</td>
                                            <td>
                                                @if (o.Plan == "Pro")
                                                {
                                                    <span class="badge bg-purple-lt text-purple">Pro</span>
                                                }
                                                else if (o.Plan == "Basic")
                                                {
                                                    <span class="badge bg-info-lt text-info">Basic</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary-lt text-secondary">@o.Plan</span>
                                                }
                                            </td>
                                            <td class="text-muted">@o.Amount.ToString("N0") ₫</td>
                                            <td>
                                                @if (o.Status == "Completed")
                                                {
                                                    <span class="badge bg-success-lt text-success">Thành công</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger-lt text-danger">Thất bại</span>
                                                }
                                            </td>
                                            <td class="text-muted">@(o.CardLastFour != null ? $"**** {o.CardLastFour}" : "—")</td>
                                            <td class="text-muted">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="ti ti-receipt-off me-2"></i>Chưa có đơn đăng ký nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>

