@model Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center">

    <!-- Hero Section -->
    <div class="row mb-5" data-aos="fade-up">
        <div class="col-12">
            <div class="card bg-primary text-white">
                <div class="card-body py-5 text-center">
                    <h1 class="display-4 fw-bold mb-3">Hệ thống Quản lý Doanh nghiệp</h1>
                    <p class="lead mb-0">Giải pháp toàn diện để quản lý doanh nghiệp, gian hàng và tài nguyên một cách hiệu quả.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-5">
        <div class="col-md-3 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="0">
            <div class="card stats-card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Tổng Doanh nghiệp</h6>
                            <h2 class="stats-number mb-0">
                                @if (Model.IsLoggedIn)
                                {
                                    @Model.TotalBusinesses
                                }
                                else
                                {
                                    <span class="text-muted fs-4">–</span>
                                }
                            </h2>
                        </div>
                        <i class="bi bi-building stats-icon text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card stats-card success h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Tổng Gian hàng</h6>
                            <h2 class="stats-number mb-0">
                                @if (Model.IsLoggedIn)
                                {
                                    @Model.TotalStalls
                                }
                                else
                                {
                                    <span class="text-muted fs-4">–</span>
                                }
                            </h2>
                        </div>
                        <i class="bi bi-shop stats-icon text-success"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card stats-card warning h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Người dùng đăng ký</h6>
                            <h2 class="stats-number mb-0">
                                @if (Model.IsAdmin)
                                {
                                    @Model.TotalUsers
                                }
                                else
                                {
                                    <span class="text-muted fs-4">–</span>
                                }
                            </h2>
                        </div>
                        <i class="bi bi-people stats-icon text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card stats-card info h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-2">Ngôn ngữ hỗ trợ</h6>
                            <h2 class="stats-number mb-0">@Model.TotalLanguages</h2>
                        </div>
                        <i class="bi bi-translate stats-icon text-info"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Subscription banner cho BusinessOwner đã đăng nhập -->
    @if (Model.IsLoggedIn && Model.UserRole == "BusinessOwner")
    {
        <div class="row mb-4" data-aos="fade-up">
            <div class="col-12">
                @{
                    var bannerCss = Model.PlanIsExpired ? "alert-warning" :
                        Model.EffectivePlan == "Pro" ? "alert-success" :
                        Model.EffectivePlan == "Basic" ? "alert-info" : "alert-secondary";
                    var planBadge = Model.EffectivePlan switch
                    {
                        "Pro" => "bg-success",
                        "Basic" => "bg-info",
                        _ => "bg-secondary"
                    };
                }
                <div class="alert @bannerCss d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <i class="ti ti-credit-card me-2"></i>
                        Gói hiện tại:
                        <span class="badge @planBadge text-white ms-1">@Model.EffectivePlan</span>
                        @if (Model.PlanIsExpired)
                        {
                            <span class="ms-2 text-danger fw-semibold">— Đã hết hạn</span>
                        }
                        else if (Model.PlanExpiresAt.HasValue)
                        {
                            <span class="ms-2 text-muted">— hết hạn @Model.PlanExpiresAt.Value.ToLocalTime().ToString("dd/MM/yyyy")</span>
                        }
                    </div>
                    <a asp-controller="Subscription" asp-action="Plans" class="btn btn-sm btn-primary">
                        <i class="ti ti-layout-grid me-1"></i>
                        @(Model.EffectivePlan == "Free" || Model.PlanIsExpired ? "Nâng cấp gói" : "Xem bảng giá")
                    </a>
                </div>
            </div>
        </div>
    }

    <!-- Pricing Section (chỉ hiển thị cho khách chưa đăng nhập) -->
    @if (!Model.IsLoggedIn)
    {
        <div class="row mb-5 text-start" data-aos="fade-up">
            <div class="col-12 text-center mb-4">
                <h2 class="fw-bold">Chọn gói phù hợp với bạn</h2>
                <p class="text-muted">Thanh toán hàng tháng, huỷ bất cứ lúc nào</p>
            </div>

            <!-- Free -->
            <div class="col-md-4 col-lg-4 mb-3" data-aos="zoom-in" data-aos-delay="0">
                <div class="card shadow-sm h-100">
                    <div class="card-header text-center py-3">
                        <div class="h3 mb-0">Free</div>
                        <div class="text-muted small">Mãi mãi miễn phí</div>
                    </div>
                    <div class="card-body">
                        <div class="display-5 fw-bold text-center mb-3">0đ</div>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>1 gian hàng</li>
                            <li class="mb-2 text-muted"><i class="ti ti-x text-danger me-2"></i>Không có TTS</li>
                            <li class="mb-2 text-muted"><i class="ti ti-x text-danger me-2"></i>Không có đa ngôn ngữ</li>
                            <li class="mb-2 text-muted"><i class="ti ti-x text-danger me-2"></i>Không hỗ trợ ưu tiên</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 px-4">
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-secondary w-100">
                            Bắt đầu miễn phí
                        </a>
                    </div>
                </div>
            </div>

            <!-- Basic -->
            <div class="col-md-4 col-lg-4 mb-3" data-aos="zoom-in" data-aos-delay="100">
                <div class="card shadow-sm h-100">
                    <div class="card-header text-center py-3">
                        <div class="h3 mb-0">Basic</div>
                        <div class="text-muted small">Phù hợp cho cửa hàng nhỏ</div>
                    </div>
                    <div class="card-body">
                        <div class="display-5 fw-bold text-center mb-1">199.000đ</div>
                        <div class="text-center text-muted small mb-3">/ tháng</div>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>Tối đa 3 gian hàng</li>
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>TTS đầy đủ</li>
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>Tất cả ngôn ngữ</li>
                            <li class="mb-2 text-muted"><i class="ti ti-x text-danger me-2"></i>Không hỗ trợ ưu tiên</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 px-4">
                        <a href="@Url.Action("Login", "Auth", new { returnUrl = Url.Action("Checkout", "Subscription", new { plan = "Basic" }) })"
                           class="btn btn-outline-primary w-100">
                            Đăng ký Basic
                        </a>
                    </div>
                </div>
            </div>

            <!-- Pro -->
            <div class="col-md-4 col-lg-4 mb-3" data-aos="zoom-in" data-aos-delay="200">
                <div class="card shadow-lg border-primary h-100 position-relative">
                    <div class="position-absolute top-0 start-50 translate-middle">
                        <span class="badge bg-primary px-3 py-1">Phổ biến nhất</span>
                    </div>
                    <div class="card-header text-center py-3 border-primary">
                        <div class="h3 mb-0 text-primary">Pro</div>
                        <div class="text-muted small">Không giới hạn tăng trưởng</div>
                    </div>
                    <div class="card-body">
                        <div class="display-5 fw-bold text-center text-primary mb-1">499.000đ</div>
                        <div class="text-center text-muted small mb-3">/ tháng</div>
                        <ul class="list-unstyled mb-4">
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i><strong>Không giới hạn</strong> gian hàng</li>
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>TTS đầy đủ</li>
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>Tất cả ngôn ngữ</li>
                            <li class="mb-2"><i class="ti ti-check text-success me-2"></i>Hỗ trợ ưu tiên</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 px-4">
                        <a href="@Url.Action("Login", "Auth", new { returnUrl = Url.Action("Checkout", "Subscription", new { plan = "Pro" }) })"
                           class="btn btn-primary w-100">
                            Đăng ký Pro
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Quick Access (chỉ hiển thị khi đã đăng nhập) -->
    @if (Model.IsLoggedIn)
    {
        <div class="row mb-5">
            <div class="col-12" data-aos="fade-up">
                <h2 class="mb-4">Truy cập nhanh</h2>
            </div>

            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card h-100 hover-shadow">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-primary-lt d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-building fs-1 text-primary"></i>
                        </div>
                        <h5 class="card-title">Quản lý Doanh nghiệp</h5>
                        <p class="card-text text-muted">Quản lý toàn bộ doanh nghiệp, chi tiết và các gian hàng liên kết từ một nơi tập trung.</p>
                        <a asp-controller="Business" asp-action="Index" class="btn btn-outline-primary">Quản lý Doanh nghiệp</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 hover-shadow">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-success-lt d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-shop fs-1 text-success"></i>
                        </div>
                        <h5 class="card-title">Quản lý Gian hàng</h5>
                        <p class="card-text text-muted">Cấu hình và tổ chức gian hàng, thiết lập vị trí và quản lý tài nguyên trên tất cả địa điểm.</p>
                        <a asp-controller="Stall" asp-action="Index" class="btn btn-outline-success">Quản lý Gian hàng</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="200">
                <div class="card h-100 hover-shadow">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-warning-lt d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-mic fs-1 text-warning"></i>
                        </div>
                        <h5 class="card-title">Nội dung Thuyết minh</h5>
                        <p class="card-text text-muted">Quản lý kịch bản thuyết minh đa ngôn ngữ và nội dung audio cho từng gian hàng.</p>
                        <a asp-controller="Narration" asp-action="StallNarrationContents" class="btn btn-outline-warning">Quản lý Thuyết minh</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="0">
                <div class="card h-100 hover-shadow">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-danger-lt d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-map fs-1 text-danger"></i>
                        </div>
                        <h5 class="card-title">Vị trí Gian hàng</h5>
                        <p class="card-text text-muted">Xem và quản lý vị trí gian hàng trên bản đồ tương tác để dễ dàng theo dõi.</p>
                        <a asp-controller="StallLocation" asp-action="Index" class="btn btn-outline-danger">Quản lý Vị trí</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-6 mb-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card h-100 hover-shadow">
                    <div class="card-body text-center py-4">
                        <div class="rounded-circle bg-secondary-lt d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-images fs-1 text-secondary"></i>
                        </div>
                        <h5 class="card-title">Media Gian hàng</h5>
                        <p class="card-text text-muted">Tải lên và quản lý hình ảnh, tệp media cho từng gian hàng.</p>
                        <a asp-controller="StallMedia" asp-action="Index" class="btn btn-outline-secondary">Quản lý Media</a>
                    </div>
                </div>
            </div>

        </div>
    }

    <!-- Trạng thái hệ thống -->
    <div class="row" data-aos="fade-up">
        <div class="col-lg-4 mb-4 mx-auto">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ti ti-server me-2"></i>Trạng thái Hệ thống</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>API Server</span>
                        <span class="badge bg-success">Trực tuyến</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Cơ sở dữ liệu</span>
                        <span class="badge bg-success">Đã kết nối</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Azure Speech / Blob</span>
                        <span class="badge bg-success">Đang chạy</span>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between align-items-center">
                        <span>Phiên bản</span>
                        <span class="badge bg-secondary">v1.0.0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
