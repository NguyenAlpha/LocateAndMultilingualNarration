
@{
    ViewData["Title"] = "Error";
}
<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 6rem;"></i>
            </div>
            <h1 class="display-4 fw-bold text-danger mb-3">Oops! Something went wrong</h1>
            <p class="lead text-muted mb-4">We're sorry, but an unexpected error has occurred. Our team has been notified and is working to fix the issue.</p>
                    
            <div class="card bg-light mb-4">
                <div class="card-body">
                    <h5 class="card-title">Error Details</h5>
                    <p class="card-text text-muted">
                        <strong>Error Code:</strong> 500<br>
                        <strong>Request ID:</strong> <code>ERR-2026-0316-A7B3F</code><br>
                        <strong>Timestamp:</strong> March 16, 2026 at 14:32:45 UTC
                    </p>
                </div>
            </div>

            <div class="d-flex justify-content-center gap-3 flex-wrap mb-5">
                <a href="/Pages/Home/Index.html" class="btn btn-primary btn-lg">
                    <i class="bi bi-house-door me-2"></i>Go to Home
                </a>
                <button type="button" class="btn btn-outline-secondary btn-lg" onclick="history.back()">
                    <i class="bi bi-arrow-left me-2"></i>Go Back
                </button>
            </div>

            <hr class="my-4">

            <h5 class="mb-3">What can you do?</h5>
            <div class="row text-start">
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-arrow-clockwise text-primary fs-1 mb-3"></i>
                            <h6>Refresh the Page</h6>
                            <p class="small text-muted mb-0">Sometimes a simple refresh can resolve temporary issues.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-clock-history text-primary fs-1 mb-3"></i>
                            <h6>Try Again Later</h6>
                            <p class="small text-muted mb-0">The issue might be temporary. Please try again in a few minutes.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-headset text-primary fs-1 mb-3"></i>
                            <h6>Contact Support</h6>
                            <p class="small text-muted mb-0">If the problem persists, please reach out to our support team.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <p class="text-muted">Need immediate assistance?</p>
                <a href="mailto:support@ems-system.com" class="btn btn-outline-primary">
                    <i class="bi bi-envelope me-2"></i>Contact Support
                </a>
            </div>
        </div>
    </div>
</div>